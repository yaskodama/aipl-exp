<!DOCTYPE html><html lang="ja"><meta charset="UTF-8"><style>li.completed .todo-text{text-decoration:line-through}</style><body><input type="text" data-testid="new-todo-input" placeholder="やることを入力"><button data-testid="add-btn">追加</button><div class="filters"><button data-testid="filter-all">全て</button><button data-testid="filter-active">未完了</button><button data-testid="filter-completed">完了</button></div><ul data-testid="todo-list"></ul><button data-testid="clear-completed">完了を一括削除</button><script>(()=>{const k='todos.v1',fk='todos.filter',$=s=>document.querySelector(s),L=$('[data-testid=todo-list]'),I=$('[data-testid=new-todo-input]');let t=JSON.parse(localStorage.getItem(k)||'[]'),f=localStorage.getItem(fk)||'all';const S=()=>{localStorage.setItem(k,JSON.stringify(t));localStorage.setItem(fk,f);R()},R=()=>{const a=t.filter(x=>f=='all'||(f=='completed'?x.completed:!x.completed));L.innerHTML=a.map(x=>`<li data-testid="todo-item" data-id="${x.id}" class="${x.completed?'completed':''}"><input type=checkbox data-testid="todo-toggle" ${x.completed?'checked':''}><span data-testid="todo-text" class="todo-text">${x.text}</span><button data-testid="todo-delete">削除</button></li>`).join('')},add=()=>{const v=I.value.trim();if(!v)return;t.push({id:Date.now()+Math.random(),text:v,completed:false});I.value='';I.focus();S()};$('[data-testid=add-btn]').onclick=add;I.onkeydown=e=>e.key=='Enter'&&add();document.querySelector('.filters').onclick=e=>{if(e.target.tagName=='BUTTON'){f=e.target.dataset.testid.replace('filter-','');S()}};$('[data-testid=clear-completed]').onclick=()=>{t=t.filter(x=>!x.completed);S()};L.onclick=e=>{const li=e.target.closest('li[data-id]');if(!li)return;const id=+li.dataset.id;if(e.target.dataset.testid=='todo-delete')t=t.filter(x=>x.id!=id);else if(e.target.dataset.testid=='todo-toggle'){const o=t.find(x=>x.id==id);if(o)o.completed=!o.completed;}else return;S()};L.ondblclick=e=>{const s=e.target;if(!s.matches('[data-testid="todo-text"]'))return;s.contentEditable='true';s.focus()};L.onfocusout=e=>{const s=e.target;if(s.dataset.testid!='todo-text'||s.contentEditable!='true')return;s.contentEditable='false';const id=+s.closest('li').dataset.id,o=t.find(x=>x.id==id),n=s.textContent.trim();if(o&&n)o.text=n;else if(o)s.textContent=o.text;S()};L.onkeydown=e=>{const s=e.target;if(s.dataset.testid!='todo-text'||s.contentEditable!='true')return;if(e.key=='Enter'||e.key=='Escape'){e.preventDefault();if(e.key=='Escape'){const id=+s.closest('li').dataset.id,o=t.find(x=>x.id==id);if(o)s.textContent=o.text}s.blur()}};R()})();</script></body></html>