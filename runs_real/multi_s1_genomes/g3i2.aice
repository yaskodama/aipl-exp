<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Todo App</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, sans-serif; background: #f0f2f5; display: flex; justify-content: center; padding: 40px 16px; min-height: 100vh; }
  .container { background: #fff; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); padding: 32px; width: 100%; max-width: 520px; height: fit-content; }
  h1 { text-align: center; margin-bottom: 24px; color: #333; font-size: 28px; }
  .input-row { display: flex; gap: 8px; margin-bottom: 16px; }
  #new-todo-input { flex: 1; padding: 10px 14px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px; outline: none; transition: border-color 0.2s; }
  #new-todo-input:focus { border-color: #4a90e2; }
  #add-btn { padding: 10px 18px; background: #4a90e2; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; transition: background 0.2s; }
  #add-btn:hover { background: #357abd; }
  .filter-row { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .filter-row button { flex: 1; padding: 8px; border: 1px solid #ccc; border-radius: 4px; background: #fff; cursor: pointer; font-size: 14px; transition: background 0.2s, color 0.2s; }
  .filter-row button.active { background: #4a90e2; color: #fff; border-color: #4a90e2; }
  .filter-row button:hover:not(.active) { background: #e8f0fb; }
  #todo-list { list-style: none; margin-bottom: 16px; }
  li[data-testid="todo-item"] { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-bottom: 1px solid #eee; }
  li[data-testid="todo-item"]:last-child { border-bottom: none; }
  li[data-testid="todo-item"].hidden { display: none; }
  li[data-testid="todo-item"].completed span[data-testid="todo-text"] { text-decoration: line-through; color: #aaa; }
  input[data-testid="todo-toggle"] { width: 18px; height: 18px; cursor: pointer; accent-color: #4a90e2; flex-shrink: 0; }
  span[data-testid="todo-text"] { flex: 1; font-size: 16px; color: #333; word-break: break-word; padding: 2px 4px; }
  span[data-testid="todo-text"].completed { text-decoration: line-through; color: #aaa; }
  span[data-testid="todo-text"][contenteditable="true"] { outline: 1px solid #4a90e2; border-radius: 4px; background: #fff; }
  li[data-testid="todo-item"].editing span[data-testid="todo-text"] { /* used if needed */ }
  .edit-input { flex: 1; font-size: 16px; padding: 2px 6px; border: 1px solid #4a90e2; border-radius: 4px; outline: none; display: none; }
  li[data-testid="todo-item"].editing .edit-input { display: block; }
  button[data-testid="todo-delete"] { padding: 4px 10px; background: #e74c3c; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; flex-shrink: 0; transition: background 0.2s; }
  button[data-testid="todo-delete"]:hover { background: #c0392b; }
  .bottom-row { display: flex; justify-content: flex-end; }
  #clear-completed { padding: 8px 14px; background: #e74c3c; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; transition: background 0.2s; }
  #clear-completed:hover { background: #c0392b; }
  .empty-msg { text-align: center; color: #bbb; padding: 20px 0; font-size: 15px; }
</style>
</head>
<body>
<div class="container">
  <h1>📝 Todo</h1>
  <div class="input-row">
    <input type="text" data-testid="new-todo-input" id="new-todo-input" placeholder="新しいタスクを入力...">
    <button data-testid="add-btn" id="add-btn">追加</button>
  </div>
  <div class="filter-row">
    <button data-testid="filter-all" id="filter-all" class="active">全て</button>
    <button data-testid="filter-active" id="filter-active">未完了</button>
    <button data-testid="filter-completed" id="filter-completed">完了</button>
  </div>
  <ul data-testid="todo-list" id="todo-list"></ul>
  <div class="bottom-row">
    <button data-testid="clear-completed" id="clear-completed">完了を一括削除</button>
  </div>
</div>

<script>
(function() {
  // Storage key - from parent A
  const STORAGE_KEY = 'todo_app_items';

  // App state - from parent A
  let todos = [];
  let currentFilter = 'all';

  // Load from localStorage - from parent A
  function loadFromStorage() {
    try {
      const data = localStorage.getItem(STORAGE_KEY);
      if (data) { todos = JSON.parse(data); }
    } catch(e) { todos = []; }
  }

  // Save to localStorage - from parent A
  function saveToStorage() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(todos)); } catch(e) {}
  }

  // ID generator - from parent A
  function generateId() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2);
  }

  // Apply current filter to DOM items - combined (from parent A + B)
  function applyFilter() {
    const items = document.querySelectorAll('li[data-testid="todo-item"]');
    items.forEach(li => {
      const id = li.dataset.id;
      const todo = todos.find(t => t.id === id);
      if (!todo) return;
      let visible = true;
      if (currentFilter === 'active' && todo.completed) visible = false; // from both
      if (currentFilter === 'completed' && !todo.completed) visible = false; // from both
      // from parent B / A: toggle hidden class
      li.classList.toggle('hidden', !visible); // from parent B
      // from parent A: also set inline display to be safe for some tests
      li.style.display = visible ? '' : 'none'; // from parent A
    });
  }

  // Create individual todo li element - base from parent A, enhanced with empty-message handling from B
  function createTodoElement(todo) {
    const li = document.createElement('li');
    li.setAttribute('data-testid', 'todo-item');
    li.dataset.id = todo.id;
    if (todo.completed) li.classList.add('completed');

    // Checkbox - from parent A/B
    const checkbox = document.createElement('input');
    checkbox.type = 'checkbox';
    checkbox.setAttribute('data-testid', 'todo-toggle');
    checkbox.checked = todo.completed;
    checkbox.addEventListener('change', () => toggleTodo(todo.id)); // from parent A

    // Text span - from parent A (contenteditable) with improvements
    const span = document.createElement('span');
    span.setAttribute('data-testid', 'todo-text');
    span.textContent = todo.text;
    if (todo.completed) span.classList.add('completed');

    // Support editing via contenteditable on double click - from parent A
    span.addEventListener('dblclick', () => {
      // mark editing state (from parent B style)
      li.classList.add('editing'); // from parent B
      const orig = span.textContent;
      span.setAttribute('contenteditable', 'true'); // from parent A
      span.focus();
      // select all text - from parent A
      const range = document.createRange();
      range.selectNodeContents(span);
      const sel = window.getSelection();
      sel.removeAllRanges();
      sel.addRange(range);

      // store original text in dataset for escape behavior
      li.dataset._orig = orig;
    });

    // finish editing logic - from parent A
    function finishEditCommit() {
      if (span.getAttribute('contenteditable') !== 'true') return;
      const newText = span.textContent.trim();
      const orig = li.dataset._orig || '';
      if (newText) {
        todo.text = newText;
        span.textContent = newText;
      } else {
        // if empty, revert to original text to avoid empty todo - from parent A
        span.textContent = orig;
      }
      span.removeAttribute('contenteditable');
      li.classList.remove('editing'); // from parent B
      delete li.dataset._orig;
      saveToStorage(); // from parent A
    }

    // on blur, commit edit - from parent A
    span.addEventListener('blur', () => {
      finishEditCommit();
    });

    // key handling while editing - from parent A
    span.addEventListener('keydown', e => {
      if (span.getAttribute('contenteditable') !== 'true') return;
      if (e.key === 'Enter') {
        e.preventDefault();
        span.blur(); // triggers commit - from parent A
      } else if (e.key === 'Escape') {
        // revert changes - from parent A
        const orig = li.dataset._orig || '';
        span.textContent = orig;
        span.removeAttribute('contenteditable');
        li.classList.remove('editing'); // from parent B
        delete li.dataset._orig;
        span.blur();
      }
    });

    // Delete button - from parent B/A
    const deleteBtn = document.createElement('button');
    deleteBtn.setAttribute('data-testid', 'todo-delete');
    deleteBtn.textContent = '削除';
    deleteBtn.addEventListener('click', () => deleteTodo(todo.id)); // from parent B

    li.appendChild(checkbox);
    li.appendChild(span);
    li.appendChild(deleteBtn);

    return li;
  }

  // Render the whole list - from parent B with storage from A
  function renderList() {
    const list = document.getElementById('todo-list');
    list.innerHTML = '';
    if (todos.length === 0) {
      // empty message handling - from parent B
      const msg = document.createElement('li');
      msg.className = 'empty-msg';
      msg.textContent = 'タスクがありません';
      list.appendChild(msg);
      return;
    }
    todos.forEach(todo => {
      const li = createTodoElement(todo);
      list.appendChild(li);
    });
    applyFilter(); // from parent A/B
  }

  // Add todo - from parent A with empty-msg handling from B
  function addTodo(text) {
    const trimmed = text.trim();
    if (!trimmed) return;
    const todo = { id: generateId(), text: trimmed, completed: false }; // from parent A
    todos.push(todo);
    saveToStorage(); // from parent A
    const list = document.getElementById('todo-list');
    // remove empty message if present - from parent B
    const emptyMsg = list.querySelector('.empty-msg'); // from parent B
    if (emptyMsg) list.removeChild(emptyMsg); // from parent B
    const li = createTodoElement(todo);
    list.appendChild(li);
    applyFilter(); // from parent A/B
  }

  // Toggle todo completed - from parent A
  function toggleTodo(id) {
    const todo = todos.find(t => t.id === id);
    if (!todo) return;
    todo.completed = !todo.completed;
    saveToStorage(); // from parent A
    const li = document.querySelector(`li[data-id="${id}"]`);
    if (li) {
      const span = li.querySelector('[data-testid="todo-text"]');
      const cb = li.querySelector('[data-testid="todo-toggle"]');
      span.classList.toggle('completed', todo.completed); // from parent A
      li.classList.toggle('completed', todo.completed); // from parent A
      cb.checked = todo.completed; // from parent A
    }
    applyFilter(); // from parent A/B
  }

  // Delete todo - from parent B with storage update from A
  function deleteTodo(id) {
    todos = todos.filter(t => t.id !== id); // from parent B
    saveToStorage(); // from parent A
    const li = document.querySelector(`li[data-id="${id}"]`);
    if (li) li.remove(); // from parent B
    const list = document.getElementById('todo-list');
    // if list empty, show empty message - from parent B
    // count remaining todo-item elements (not counting empty-msg)
    const remaining = list.querySelectorAll('li[data-testid="todo-item"]').length;
    if (remaining === 0) {
      const msg = document.createElement('li');
      msg.className = 'empty-msg';
      msg.textContent = 'タスクがありません';
      list.appendChild(msg);
    }
  }

  // Set filter and update UI - from parent B/A
  function setFilter(filter) {
    currentFilter = filter; // from parent B
    document.getElementById('filter-all').classList.toggle('active', filter === 'all'); // from parent B
    document.getElementById('filter-active').classList.toggle('active', filter === 'active'); // from parent B
    document.getElementById('filter-completed').classList.toggle('active', filter === 'completed'); // from parent B
    applyFilter(); // from parent A/B
  }

  // Event listeners for add button and enter key - from parent A/B
  document.getElementById('add-btn').addEventListener('click', () => {
    const input = document.getElementById('new-todo-input');
    addTodo(input.value); // from parent A
    input.value = '';
    input.focus();
  });

  document.getElementById('new-todo-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      const input = document.getElementById('new-todo-input');
      addTodo(input.value); // from parent A
      input.value = '';
    }
  });

  // Filter buttons - from parent B
  document.getElementById('filter-all').addEventListener('click', () => setFilter('all')); // from parent B
  document.getElementById('filter-active').addEventListener('click', () => setFilter('active')); // from parent B
  document.getElementById('filter-completed').addEventListener('click', () => setFilter('completed')); // from parent B

  // Clear completed - from both
  document.getElementById('clear-completed').addEventListener('click', () => {
    todos = todos.filter(t => !t.completed); // from parent B
    saveToStorage(); // from parent A
    renderList(); // from parent B
  });

  // Initialize - load storage then render - from parent A/B
  loadFromStorage(); // from parent A
  renderList(); // from parent B
})();
</script>
</body>
</html>