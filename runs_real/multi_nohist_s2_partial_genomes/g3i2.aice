<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Todo App</title>
<style>
*{box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f5f5f5;margin:0;padding:20px;min-height:100vh}
.container{max-width:600px;margin:0 auto;background:#fff;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.1);padding:24px}
h1{text-align:center;color:#333;margin-top:0}
.input-row{display:flex;gap:8px;margin-bottom:16px}
.input-row input{flex:1;padding:10px;font-size:16px;border:1px solid #ccc;border-radius:4px}
.input-row button{padding:10px 18px;font-size:16px;background:#4a90e2;color:#fff;border:none;border-radius:4px;cursor:pointer}
.input-row button:hover{background:#357abd}
.filters{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.filters button{padding:6px 12px;background:#eee;border:1px solid #ccc;border-radius:4px;cursor:pointer}
.filters button.active{background:#4a90e2;color:#fff;border-color:#4a90e2}
.clear-btn{margin-left:auto;background:#e74c3c!important;color:#fff!important;border-color:#e74c3c!important}
.todo-list{list-style:none;padding:0;margin:0}
li{display:flex;align-items:center;gap:8px;padding:10px;border-bottom:1px solid #eee}
li:last-child{border-bottom:none}
li.completed, li.completed .todo-text{text-decoration:line-through;color:#999}
.todo-text{flex:1;padding:4px;outline:none;word-break:break-all}
.todo-text[contenteditable="true"]{background:#fff8d6;border:1px dashed #999;border-radius:3px}
.delete-btn{padding:4px 10px;background:#e74c3c;color:#fff;border:none;border-radius:4px;cursor:pointer}
.delete-btn:hover{background:#c0392b}
.empty{text-align:center;color:#999;padding:20px}
</style>
</head>
<body>
<div class="container">
  <h1>Todo App</h1>
  <div class="input-row">
    <input type="text" data-testid="new-todo-input" id="newTodoInput" placeholder="新しいタスクを入力...">
    <button data-testid="add-btn" id="addBtn">追加</button>
  </div>
  <div class="filters">
    <button data-testid="filter-all" id="filterAll" class="active">全て</button>
    <button data-testid="filter-active" id="filterActive">未完了</button>
    <button data-testid="filter-completed" id="filterCompleted">完了</button>
    <button data-testid="clear-completed" id="clearCompleted" class="clear-btn">完了を一括削除</button>
  </div>
  <ul data-testid="todo-list" id="todoList" class="todo-list"></ul>
</div>
<script>
(() => {
  const STORAGE_KEY = 'todos_v1'; // from parent A/B (both used same key)
  const FILTER_KEY = 'todos_filter_v1'; // from parent A/B
  let todos = []; // array of {id,text,completed}
  let filter = 'all';

  const input = document.getElementById('newTodoInput'); // data-testid="new-todo-input"
  const addBtn = document.getElementById('addBtn'); // data-testid="add-btn"
  const listEl = document.getElementById('todoList'); // data-testid="todo-list"
  const filterAllBtn = document.getElementById('filterAll'); // data-testid="filter-all"
  const filterActiveBtn = document.getElementById('filterActive'); // data-testid="filter-active"
  const filterCompletedBtn = document.getElementById('filterCompleted'); // data-testid="filter-completed"
  const clearCompletedBtn = document.getElementById('clearCompleted'); // data-testid="clear-completed"

  // load/save logic (from both parents - identical)
  function load() { // from parent A
    try {
      const d = localStorage.getItem(STORAGE_KEY);
      if (d) todos = JSON.parse(d) || [];
      const ff = localStorage.getItem(FILTER_KEY);
      if (ff) filter = ff;
    } catch (e) {
      todos = [];
    }
  }

  function save() { // from parent A
    localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
    localStorage.setItem(FILTER_KEY, filter);
  }

  // add item (from parent A)
  function addTodo(text) { // from parent A
    text = (text || '').trim();
    if (!text) return;
    todos.push({
      id: Date.now() + '_' + Math.random().toString(36).slice(2, 7),
      text,
      completed: false
    });
    save();
    render();
  }

  // delete item (from parent A, with stopPropagation usage from parent B in render)
  function deleteTodo(id) { // from parent A
    todos = todos.filter(t => t.id !== id);
    save();
    render();
  }

  // toggle completed (from parent A)
  function toggleTodo(id) { // from parent A
    const t = todos.find(x => x.id === id);
    if (t) t.completed = !t.completed;
    save();
    render();
  }

  // update text (from parent A)
  function updateTodo(id, newText) { // from parent A
    const t = todos.find(x => x.id === id);
    if (t) {
      newText = newText.trim();
      if (newText) t.text = newText;
    }
    save();
    render();
  }

  // clear completed (from parent A)
  function clearCompleted() { // from parent A
    todos = todos.filter(t => !t.completed);
    save();
    render();
  }

  // set filter (from parent A)
  function setFilter(f) { // from parent A
    filter = f;
    save();
    render();
  }

  // render function integrates behavior from both parents:
  // - empty message behavior from parent A
  // - double-click to edit attached to li (parent B) and to span (parent A) for robustness
  // - delete button stopPropagation from parent B
  function render() {
    filterAllBtn.classList.toggle('active', filter === 'all');
    filterActiveBtn.classList.toggle('active', filter === 'active');
    filterCompletedBtn.classList.toggle('active', filter === 'completed');

    listEl.innerHTML = '';

    const visible = todos.filter(t => {
      if (filter === 'all') return true;
      if (filter === 'active') return !t.completed;
      if (filter === 'completed') return t.completed;
    });

    if (visible.length === 0) { // from parent A
      const e = document.createElement('li'); // empty message li (no data-testid)
      e.className = 'empty';
      e.textContent = todos.length === 0 ? 'タスクはありません' : '該当する項目はありません';
      listEl.appendChild(e);
      return;
    }

    visible.forEach(t => {
      const li = document.createElement('li');
      li.setAttribute('data-testid', 'todo-item'); // required
      li.dataset.id = t.id;
      if (t.completed) li.classList.add('completed');

      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.setAttribute('data-testid', 'todo-toggle'); // required
      cb.checked = t.completed;
      cb.addEventListener('change', () => toggleTodo(t.id)); // from parent A

      const span = document.createElement('span');
      span.setAttribute('data-testid', 'todo-text'); // required
      span.className = 'todo-text';
      span.textContent = t.text;

      // Editing behavior:
      // - parent A: dblclick on span to set contenteditable
      // - parent B: dblclick on li to set both li and span contenteditable
      const startEdit = () => { // from parent B (li dblclick) and parent A (span dblclick)
        span.setAttribute('contenteditable', 'true'); // from parent A
        li.setAttribute('contenteditable', 'true'); // from parent B
        span.focus();
        try {
          const r = document.createRange();
          r.selectNodeContents(span);
          r.collapse(false);
          const sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(r);
        } catch (e) {
          // ignore selection errors
        }
      };

      // attach both to be resilient
      li.addEventListener('dblclick', startEdit); // from parent B
      span.addEventListener('dblclick', startEdit); // from parent A

      // blur: save edits (from parent A)
      span.addEventListener('blur', () => {
        if (span.getAttribute('contenteditable') === 'true') {
          span.removeAttribute('contenteditable'); // from parent A
          li.removeAttribute('contenteditable'); // from parent B
          updateTodo(t.id, span.textContent);
        }
      });

      // keyboard handling during edit: Enter to finish, Escape to cancel (from both parents)
      span.addEventListener('keydown', e => {
        if (e.key === 'Enter') {
          e.preventDefault();
          span.blur(); // commit
        } else if (e.key === 'Escape') {
          e.preventDefault();
          span.textContent = t.text; // revert
          span.removeAttribute('contenteditable');
          li.removeAttribute('contenteditable');
          span.blur();
        }
      });

      const delBtn = document.createElement('button');
      delBtn.setAttribute('data-testid', 'todo-delete'); // required
      delBtn.className = 'delete-btn';
      delBtn.textContent = '削除';
      delBtn.addEventListener('click', ev => {
        ev.stopPropagation(); // from parent B to avoid triggering li dblclick/edit
        deleteTodo(t.id);
      });

      li.appendChild(cb);
      li.appendChild(span);
      li.appendChild(delBtn);

      listEl.appendChild(li);
    });
  }

  // UI wiring (from parent A with small touches)
  addBtn.addEventListener('click', () => { // from parent A
    addTodo(input.value);
    input.value = '';
    input.focus();
  });

  input.addEventListener('keydown', e => { // from parent A
    if (e.key === 'Enter') {
      addTodo(input.value);
      input.value = '';
    }
  });

  filterAllBtn.addEventListener('click', () => setFilter('all')); // from parent A
  filterActiveBtn.addEventListener('click', () => setFilter('active')); // from parent A
  filterCompletedBtn.addEventListener('click', () => setFilter('completed')); // from parent A
  clearCompletedBtn.addEventListener('click', clearCompleted); // from parent A

  // initial load & render
  load(); // from parent A/B
  render(); // from parent A/B
})();
</script>
</body>
</html>