<!DOCTYPE html>
<html lang="ja"><head><meta charset="UTF-8"><title>Todo App</title><style>body{font-family:sans-serif;max-width:600px;margin:2em auto;padding:1em}h1{text-align:center}.input-row{display:flex;gap:.5em;margin-bottom:1em}#new-todo-input{flex:1;padding:.5em;font-size:1em}button{padding:.5em 1em;cursor:pointer}.filters{display:flex;gap:.5em;margin-bottom:1em;justify-content:center}.filters button.active{background:#4a90e2;color:#fff}ul{list-style:none;padding:0}li{display:flex;align-items:center;gap:.5em;padding:.5em;border-bottom:1px solid #eee}li .todo-text{flex:1}li.completed .todo-text{text-decoration:line-through;color:#999}li .todo-text[contenteditable="true"]{background:#fffbe6;outline:1px dashed #f5c000;padding:2px}</style></head><body>
<h1>Todo</h1>
<div class="input-row">
<input type="text" data-testid="new-todo-input" placeholder="何をしますか？">
<button data-testid="add-btn">追加</button>
</div>
<div class="filters">
<button data-testid="filter-all" class="active">全て</button>
<button data-testid="filter-active">未完了</button>
<button data-testid="filter-completed">完了</button>
</div>
<ul data-testid="todo-list"></ul>
<div style="text-align:center;margin-top:1em"><button data-testid="clear-completed">完了項目を削除</button></div>
<script>
(()=>{
// from parent A & B: Core storage and state management
const SK='todos-v1',FK='filter-v1';
let todos=[],filter='all';

const load=()=>{
  try{const t=localStorage.getItem(SK);todos=t?JSON.parse(t):[]}catch(e){todos=[]}
  try{const f=localStorage.getItem(FK);filter=f||'all'}catch(e){filter='all'}
};

const save=()=>{
  try{localStorage.setItem(SK,JSON.stringify(todos));localStorage.setItem(FK,filter)}catch(e){}
};

// from parent A & B: HTML escaping utility
const escapeHtml=t=>t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

// from parent A & B: Render with filtering logic
const render=()=>{
  const list=document.querySelector('[data-testid="todo-list"]');
  const visible=filter==='all'?todos:filter==='completed'?todos.filter(t=>t.completed):todos.filter(t=>!t.completed);
  list.innerHTML=visible.map(t=>`<li data-testid="todo-item" data-id="${t.id}" class="${t.completed?'completed':''}"><input type="checkbox" data-testid="todo-toggle" ${t.completed?'checked':''}><span data-testid="todo-text" class="todo-text">${escapeHtml(t.text)}</span><button data-testid="todo-delete">削除</button></li>`).join('')
};

const sync=()=>{save();render()};

// from parent A & B: Core CRUD operations
const add=()=>{
  const input=document.querySelector('[data-testid="new-todo-input"]');
  const text=input.value.trim();
  if(!text)return;
  todos.push({id:Date.now()+Math.random(),text:text,completed:false});
  input.value='';
  input.focus();
  sync()
};

const del=id=>{todos=todos.filter(t=>t.id!==id);sync()};

const toggle=id=>{
  const t=todos.find(t=>t.id===id);
  if(t){t.completed=!t.completed;sync()}
};

const setFilter=f=>{filter=f;sync()};

const clearCompleted=()=>{todos=todos.filter(t=>!t.completed);sync()};

// from parent A & B: Event listeners for add button and input
document.querySelector('[data-testid="add-btn"]').addEventListener('click',add);
document.querySelector('[data-testid="new-todo-input"]').addEventListener('keydown',e=>{if(e.key==='Enter')add()});

// from parent A & B: Filter button handlers
document.querySelector('.filters').addEventListener('click',e=>{
  if(e.target.tagName==='BUTTON'){
    const f=e.target.dataset.testid.replace('filter-','');
    setFilter(f);
    document.querySelectorAll('.filters button').forEach(b=>b.classList.remove('active'));
    e.target.classList.add('active')
  }
});

// from parent A & B: Clear completed button
document.querySelector('[data-testid="clear-completed"]').addEventListener('click',clearCompleted);

// from parent A & B: Toggle and delete handlers via event delegation
document.querySelector('[data-testid="todo-list"]').addEventListener('click',e=>{
  const li=e.target.closest('[data-testid="todo-item"]');
  if(!li)return;
  const id=+li.dataset.id;
  if(e.target.dataset.testid==='todo-delete'){del(id)}
  else if(e.target.dataset.testid==='todo-toggle'){toggle(id)}
});

// from parent A & B: Double-click to edit - contentEditable activation
document.querySelector('[data-testid="todo-list"]').addEventListener('dblclick',e=>{
  const span=e.target;
  if(span.dataset.testid!=='todo-text')return;
  span.contentEditable='true';
  span.focus();
  const range=document.createRange();
  range.selectNodeContents(span);
  const sel=window.getSelection();
  sel.removeAllRanges();
  sel.addRange(range)
});

// from parent A & B: Blur handler for edit mode completion
document.querySelector('[data-testid="todo-list"]').addEventListener('blur',e=>{
  const span=e.target;
  if(span.dataset.testid!=='todo-text'||span.contentEditable!=='true')return;
  span.contentEditable='false';
  const li=span.closest('[data-testid="todo-item"]');
  const id=+li.dataset.id;
  const t=todos.find(t=>t.id===id);
  const newText=span.textContent.trim();
  if(t&&newText){t.text=newText;sync()}
  else if(t){span.textContent=t.text}
},true);

// from parent A & B: Keydown handler for edit mode (Enter/Escape)
document.querySelector('[data-testid="todo-list"]').addEventListener('keydown',e=>{
  const span=e.target;
  if(span.dataset.testid!=='todo-text'||span.contentEditable!=='true')return;
  if(e.key==='Enter'||e.key==='Escape'){
    e.preventDefault();
    if(e.key==='Escape'){
      const li=span.closest('[data-testid="todo-item"]');
      const id=+li.dataset.id;
      const t=todos.find(t=>t.id===id);
      if(t)span.textContent=t.text
    }
    span.contentEditable='false';
    span.blur()
  }
});

// from parent A & B: Initialize on load
load();
render()
})();
</script></body></html>