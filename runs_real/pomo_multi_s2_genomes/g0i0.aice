<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pomodoro Timer</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', sans-serif;
    background: #1a1a2e;
    color: #eee;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
  }
  .container {
    background: #16213e;
    border-radius: 16px;
    padding: 40px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    text-align: center;
  }
  h1 { font-size: 1.8rem; margin-bottom: 24px; color: #e94560; }
  [data-testid="phase-display"] {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #a0a0c0;
    margin-bottom: 12px;
  }
  [data-testid="timer-display"] {
    font-size: 5rem;
    font-weight: bold;
    color: #fff;
    margin-bottom: 12px;
    font-variant-numeric: tabular-nums;
  }
  [data-testid="cycle-count"] {
    font-size: 0.9rem;
    color: #a0a0c0;
    margin-bottom: 32px;
  }
  .btn-row {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  button {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  button:hover { opacity: 0.85; }
  [data-testid="btn-start"] { background: #e94560; color: #fff; }
  [data-testid="btn-pause"] { background: #f0a500; color: #fff; }
  [data-testid="btn-reset"] { background: #444; color: #fff; }
  [data-testid="btn-skip"]  { background: #0f3460; color: #fff; border: 1px solid #e94560; }
  .settings {
    border-top: 1px solid #333;
    padding-top: 24px;
  }
  .settings h2 { font-size: 1rem; margin-bottom: 16px; color: #a0a0c0; }
  .setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .setting-row label { font-size: 0.9rem; color: #ccc; }
  .setting-row input {
    width: 80px;
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid #444;
    background: #0f3460;
    color: #fff;
    font-size: 0.95rem;
    text-align: center;
  }
  [data-testid="btn-save-settings"] {
    background: #e94560;
    color: #fff;
    width: 100%;
    padding: 12px;
    margin-top: 8px;
  }
</style>
</head>
<body>
<div class="container">
  <h1>🍅 Pomodoro</h1>
  <div data-testid="phase-display">work</div>
  <div data-testid="timer-display">25:00</div>
  <div data-testid="cycle-count">Cycles: 0</div>
  <div class="btn-row">
    <button data-testid="btn-start">Start</button>
    <button data-testid="btn-pause">Pause</button>
    <button data-testid="btn-reset">Reset</button>
    <button data-testid="btn-skip">Skip</button>
  </div>
  <div class="settings">
    <h2>Settings</h2>
    <div class="setting-row">
      <label for="setting-work">Work (min)</label>
      <input data-testid="setting-work" id="setting-work" type="number" min="1" max="99" value="25">
    </div>
    <div class="setting-row">
      <label for="setting-break">Break (min)</label>
      <input data-testid="setting-break" id="setting-break" type="number" min="1" max="99" value="5">
    </div>
    <button data-testid="btn-save-settings">Save Settings</button>
  </div>
</div>

<script>
(function() {
  // --- State ---
  var DEFAULT_WORK = 25;
  var DEFAULT_BREAK = 5;

  var workMinutes = parseInt(localStorage.getItem('pomo_work')) || DEFAULT_WORK;
  var breakMinutes = parseInt(localStorage.getItem('pomo_break')) || DEFAULT_BREAK;
  var cycleCount = parseInt(localStorage.getItem('pomo_cycles')) || 0;
  var phase = 'work'; // 'work' or 'break'
  var remainingSeconds = workMinutes * 60;
  var running = false;
  var intervalId = null;

  // --- DOM ---
  var timerDisplay = document.querySelector('[data-testid="timer-display"]');
  var phaseDisplay = document.querySelector('[data-testid="phase-display"]');
  var cycleDisplay = document.querySelector('[data-testid="cycle-count"]');
  var btnStart = document.querySelector('[data-testid="btn-start"]');
  var btnPause = document.querySelector('[data-testid="btn-pause"]');
  var btnReset = document.querySelector('[data-testid="btn-reset"]');
  var btnSkip = document.querySelector('[data-testid="btn-skip"]');
  var inputWork = document.querySelector('[data-testid="setting-work"]');
  var inputBreak = document.querySelector('[data-testid="setting-break"]');
  var btnSave = document.querySelector('[data-testid="btn-save-settings"]');

  // --- Init UI from stored settings ---
  inputWork.value = workMinutes;
  inputBreak.value = breakMinutes;

  // --- Helpers ---
  function formatTime(secs) {
    var m = Math.floor(secs / 60);
    var s = secs % 60;
    return m + ':' + (s < 10 ? '0' : '') + s;
  }

  function updateDisplay() {
    timerDisplay.textContent = formatTime(remainingSeconds);
    phaseDisplay.textContent = phase;
    cycleDisplay.textContent = 'Cycles: ' + cycleCount;
  }

  function stopInterval() {
    if (intervalId !== null) {
      clearInterval(intervalId);
      intervalId = null;
    }
    running = false;
  }

  function tick() {
    if (remainingSeconds > 0) {
      remainingSeconds--;
      updateDisplay();
    }
    if (remainingSeconds === 0) {
      stopInterval();
      onPhaseComplete();
    }
  }

  function onPhaseComplete() {
    if (phase === 'work') {
      // Transition to break
      phase = 'break';
      remainingSeconds = breakMinutes * 60;
    } else {
      // Transition to work, increment cycle
      phase = 'work';
      remainingSeconds = workMinutes * 60;
      cycleCount++;
      localStorage.setItem('pomo_cycles', cycleCount);
    }
    updateDisplay();
    // Auto-start next phase
    startTimer();
  }

  function startTimer() {
    if (running) return;
    running = true;
    intervalId = setInterval(tick, 1000);
  }

  function pauseTimer() {
    stopInterval();
  }

  function resetTimer() {
    stopInterval();
    remainingSeconds = (phase === 'work' ? workMinutes : breakMinutes) * 60;
    updateDisplay();
  }

  function skipPhase() {
    stopInterval();
    if (phase === 'work') {
      phase = 'break';
      remainingSeconds = breakMinutes * 60;
    } else {
      phase = 'work';
      remainingSeconds = workMinutes * 60;
      cycleCount++;
      localStorage.setItem('pomo_cycles', cycleCount);
    }
    updateDisplay();
  }

  function saveSettings() {
    var w = parseInt(inputWork.value);
    var b = parseInt(inputBreak.value);
    if (isNaN(w) || w < 1) w = DEFAULT_WORK;
    if (isNaN(b) || b < 1) b = DEFAULT_BREAK;
    workMinutes = w;
    breakMinutes = b;
    localStorage.setItem('pomo_work', workMinutes);
    localStorage.setItem('pomo_break', breakMinutes);
    inputWork.value = workMinutes;
    inputBreak.value = breakMinutes;
  }

  // --- Events ---
  btnStart.addEventListener('click', startTimer);
  btnPause.addEventListener('click', pauseTimer);
  btnReset.addEventListener('click', resetTimer);
  btnSkip.addEventListener('click', skipPhase);
  btnSave.addEventListener('click', saveSettings);

  // --- Initial render ---
  updateDisplay();
})();
</script>
</body>
</html>