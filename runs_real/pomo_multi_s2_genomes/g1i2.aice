<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pomodoro Timer</title>
<style>
  /* from parent B */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', sans-serif;
    background: #1a1a2e;
    color: #eee;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
  }
  .container {
    background: #16213e;
    border-radius: 16px;
    padding: 40px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    text-align: center;
  }
  h1 { font-size: 1.8rem; margin-bottom: 24px; color: #e94560; }
  [data-testid="phase-display"] {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #a0a0c0;
    margin-bottom: 12px;
  }
  [data-testid="timer-display"] {
    font-size: 5rem;
    font-weight: bold;
    color: #fff;
    margin-bottom: 12px;
    font-variant-numeric: tabular-nums;
  }
  .cycle-wrapper {
    font-size: 0.9rem;
    color: #a0a0c0;
    margin-bottom: 32px;
  }
  .btn-row {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  button {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  button:hover:not(:disabled) { opacity: 0.85; }
  /* from parent A: disabled style */
  button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  [data-testid="btn-start"] { background: #e94560; color: #fff; }
  [data-testid="btn-pause"] { background: #f0a500; color: #fff; }
  [data-testid="btn-reset"] { background: #444; color: #fff; }
  [data-testid="btn-skip"]  { background: #0f3460; color: #fff; border: 1px solid #e94560; }
  .settings {
    border-top: 1px solid #333;
    padding-top: 24px;
  }
  .settings h2 { font-size: 1rem; margin-bottom: 16px; color: #a0a0c0; }
  .setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .setting-row label { font-size: 0.9rem; color: #ccc; }
  .setting-row input {
    width: 80px;
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid #444;
    background: #0f3460;
    color: #fff;
    font-size: 0.95rem;
    text-align: center;
  }
  [data-testid="btn-save-settings"] {
    background: #e94560;
    color: #fff;
    width: 100%;
    padding: 12px;
    margin-top: 8px;
  }
</style>
</head>
<body>
<div class="container">
  <h1>🍅 Pomodoro</h1>
  <!-- from parent B: phase display as div -->
  <div data-testid="phase-display">work</div>
  <!-- from parent B: timer display as div -->
  <div data-testid="timer-display">25:00</div>
  <!-- from parent A: cycle count wrapped, with span for testid -->
  <div class="cycle-wrapper">Cycles: <span data-testid="cycle-count">0</span></div>
  <div class="btn-row">
    <!-- from parent A: start enabled, pause disabled on init -->
    <button data-testid="btn-start">Start</button>
    <button data-testid="btn-pause" disabled>Pause</button>
    <button data-testid="btn-reset">Reset</button>
    <button data-testid="btn-skip">Skip</button>
  </div>
  <div class="settings">
    <h2>Settings</h2>
    <div class="setting-row">
      <label for="setting-work">Work (min)</label>
      <!-- from parent B: max="99" attribute -->
      <input data-testid="setting-work" id="setting-work" type="number" min="1" max="99" value="25">
    </div>
    <div class="setting-row">
      <label for="setting-break">Break (min)</label>
      <input data-testid="setting-break" id="setting-break" type="number" min="1" max="99" value="5">
    </div>
    <button data-testid="btn-save-settings">Save Settings</button>
  </div>
</div>

<script>
(function() {
  // from parent B: IIFE encapsulation to avoid global scope pollution
  var DEFAULT_WORK = 25;
  var DEFAULT_BREAK = 5;

  // from parent B: localStorage keys (pomo_* prefix)
  var workMinutes  = parseInt(localStorage.getItem('pomo_work'),   10) || DEFAULT_WORK;
  var breakMinutes = parseInt(localStorage.getItem('pomo_break'),  10) || DEFAULT_BREAK;
  var cycleCount   = parseInt(localStorage.getItem('pomo_cycles'), 10) || 0;

  // from parent B: state variables
  var phase = 'work'; // 'work' or 'break'
  var remainingSeconds = workMinutes * 60;
  var running = false;
  var intervalId = null;
  // from parent A: isPaused flag for skip logic
  var isPaused = true;

  // --- DOM ---
  // from parent A: querySelector with data-testid
  var timerDisplay = document.querySelector('[data-testid="timer-display"]');
  var phaseDisplay = document.querySelector('[data-testid="phase-display"]');
  var cycleDisplay = document.querySelector('[data-testid="cycle-count"]');
  var btnStart     = document.querySelector('[data-testid="btn-start"]');
  var btnPause     = document.querySelector('[data-testid="btn-pause"]');
  var btnReset     = document.querySelector('[data-testid="btn-reset"]');
  var btnSkip      = document.querySelector('[data-testid="btn-skip"]');
  var inputWork    = document.querySelector('[data-testid="setting-work"]');
  var inputBreak   = document.querySelector('[data-testid="setting-break"]');
  var btnSave      = document.querySelector('[data-testid="btn-save-settings"]');

  // from parent B: initialise input fields from stored settings
  inputWork.value  = workMinutes;
  inputBreak.value = breakMinutes;

  // --- Helpers ---

  // from parent B: formatTime without zero-padding the minutes
  function formatTime(secs) {
    var m = Math.floor(secs / 60);
    var s = secs % 60;
    return m + ':' + (s < 10 ? '0' : '') + s;
  }

  // from parent A: updateDisplay updates timer, phase, and cycle count
  function updateDisplay() {
    timerDisplay.textContent = formatTime(remainingSeconds);
    phaseDisplay.textContent = phase;
    cycleDisplay.textContent = cycleCount;
  }

  // from parent A: button state management (disabled/enabled)
  function updateButtonStates() {
    btnStart.disabled = running;
    btnPause.disabled = !running;
  }

  // from parent B: stopInterval helper
  function stopInterval() {
    if (intervalId !== null) {
      clearInterval(intervalId);
      intervalId = null;
    }
    running = false;
    isPaused = true; // from parent A
  }

  // from parent B: tick decrements then checks for completion
  function tick() {
    if (remainingSeconds > 0) {
      remainingSeconds--;
      updateDisplay();
    }
    if (remainingSeconds === 0) {
      stopInterval();
      updateButtonStates();
      onPhaseComplete();
    }
  }

  // from parent A: handlePhaseCompletion logic (work→break increments nothing, break→work increments cycle)
  function onPhaseComplete() {
    if (phase === 'work') {
      phase = 'break';
      remainingSeconds = breakMinutes * 60;
    } else {
      phase = 'work';
      remainingSeconds = workMinutes * 60;
      cycleCount++;
      localStorage.setItem('pomo_cycles', cycleCount); // from parent A: save on increment
    }
    updateDisplay();
    // from parent A: auto-start next phase
    startTimer();
  }

  // from parent A: startTimer guards against double-start; manages button states
  function startTimer() {
    if (running) return; // from parent B: guard
    if (intervalId !== null) clearInterval(intervalId); // from parent A: safety clear
    running = true;
    isPaused = false; // from parent A
    intervalId = setInterval(tick, 1000);
    updateButtonStates(); // from parent A
  }

  // from parent A: pauseTimer with button state update
  function pauseTimer() {
    stopInterval();
    updateButtonStates(); // from parent A
  }

  // from parent A: resetTimer resets to current phase duration, stays paused
  function resetTimer() {
    stopInterval();
    remainingSeconds = (phase === 'work' ? workMinutes : breakMinutes) * 60;
    updateDisplay();
    updateButtonStates(); // from parent A
  }

  // from parent A: skipPhase preserves running state
  function skipPhase() {
    var wasRunning = running; // from parent A: remember running state
    stopInterval();

    if (phase === 'work') {
      phase = 'break';
      remainingSeconds = breakMinutes * 60;
    } else {
      phase = 'work';
      remainingSeconds = workMinutes * 60;
      cycleCount++;
      localStorage.setItem('pomo_cycles', cycleCount); // from parent A
    }
    updateDisplay();

    if (wasRunning) { // from parent A: resume if was running
      startTimer();
    } else {
      updateButtonStates(); // from parent A
    }
  }

  // from parent B: saveSettings with NaN guard (no alert)
  function saveSettings() {
    var w = parseInt(inputWork.value,  10);
    var b = parseInt(inputBreak.value, 10);
    if (isNaN(w) || w < 1) w = DEFAULT_WORK;  // from parent B: silent fallback
    if (isNaN(b) || b < 1) b = DEFAULT_BREAK; // from parent B: silent fallback
    workMinutes  = w;
    breakMinutes = b;
    localStorage.setItem('pomo_work',  workMinutes);  // from parent B: pomo_* keys
    localStorage.setItem('pomo_break', breakMinutes); // from parent B
    inputWork.value  = workMinutes;
    inputBreak.value = breakMinutes;
    // from parent A: no alert (parent B style — silent save)
  }

  // --- Events ---
  // from parent A & B: event listeners
  btnStart.addEventListener('click', startTimer);
  btnPause.addEventListener('click', pauseTimer);
  btnReset.addEventListener('click', resetTimer);
  btnSkip.addEventListener('click',  skipPhase);
  btnSave.addEventListener('click',  saveSettings);

  // --- Initial render ---
  // from parent A: update display and button states on load
  updateDisplay();
  updateButtonStates();
})();
</script>
</body>
</html>