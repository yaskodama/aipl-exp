<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pomodoro Timer</title>
<style>body{font-family:Segoe UI,sans-serif;background:#1a1a2e;color:#eee;display:flex;justify-content:center;align-items:center;min-height:100vh;padding:20px}.container{background:#16213e;border-radius:16px;padding:40px;width:100%;max-width:400px;box-shadow:0 8px 32px rgba(0,0,0,.4);text-align:center}h1{font-size:1.8rem;margin-bottom:24px;color:#e94560}[data-testid="phase-display"]{font-size:1rem;text-transform:uppercase;letter-spacing:3px;color:#a0a0c0;margin-bottom:12px}[data-testid="timer-display"]{font-size:5rem;font-weight:bold;color:#fff;margin-bottom:12px;font-variant-numeric:tabular-nums}[data-testid="cycle-count"]{font-size:.9rem;color:#a0a0c0;margin-bottom:32px}.btn-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:32px}button{padding:10px 20px;border:none;border-radius:8px;cursor:pointer;font-size:.95rem;font-weight:600;transition:opacity .2s}button:hover{opacity:.85}[data-testid="btn-start"]{background:#e94560;color:#fff}[data-testid="btn-pause"]{background:#f0a500;color:#fff}[data-testid="btn-reset"]{background:#444;color:#fff}[data-testid="btn-skip"]{background:#0f3460;color:#fff;border:1px solid #e94560}.settings{border-top:1px solid #333;padding-top:24px}.settings h2{font-size:1rem;margin-bottom:16px;color:#a0a0c0}.setting-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}.setting-row label{font-size:.9rem;color:#ccc}.setting-row input{width:80px;padding:6px 10px;border-radius:6px;border:1px solid #444;background:#0f3460;color:#fff;font-size:.95rem;text-align:center}[data-testid="btn-save-settings"]{background:#e94560;color:#fff;width:100%;padding:12px;margin-top:8px}</style>
</head>
<body>
<div class="container">
  <h1>🍅 Pomodoro</h1>
  <div data-testid="phase-display">work</div>
  <div data-testid="timer-display">25:00</div>
  <div data-testid="cycle-count">Cycles: 0</div>
  <div class="btn-row">
    <button data-testid="btn-start">Start</button>
    <button data-testid="btn-pause">Pause</button>
    <button data-testid="btn-reset">Reset</button>
    <button data-testid="btn-skip">Skip</button>
  </div>
  <div class="settings">
    <h2>Settings</h2>
    <div class="setting-row">
      <label for="setting-work">Work (min)</label>
      <input data-testid="setting-work" id="setting-work" type="number" min="1" max="99" value="25">
    </div>
    <div class="setting-row">
      <label for="setting-break">Break (min)</label>
      <input data-testid="setting-break" id="setting-break" type="number" min="1" max="99" value="5">
    </div>
    <button data-testid="btn-save-settings">Save Settings</button>
  </div>
</div>
<script>
(() => {
  "use strict";
  const d = document;
  const W = localStorage;

  // load stored settings safely as numbers
  let storedWork = parseInt(W.getItem("pomo_work"), 10);
  if (isNaN(storedWork)) storedWork = 25;
  let storedBreak = parseInt(W.getItem("pomo_break"), 10);
  if (isNaN(storedBreak)) storedBreak = 5;
  let storedCycles = parseInt(W.getItem("pomo_cycles"), 10);
  if (isNaN(storedCycles)) storedCycles = 0;

  const DEFAULT_PHASE = "work";

  let workMinutes = storedWork;
  let breakMinutes = storedBreak;
  let cycleCount = storedCycles;
  let phase = DEFAULT_PHASE;
  let remainingSeconds = workMinutes * 60;
  let running = false;
  let intervalId = null;

  const el = (id) => d.querySelector(`[data-testid="${id}"]`);
  const timerDisplay = el("timer-display");
  const phaseDisplay = el("phase-display");
  const cycleDisplay = el("cycle-count");
  const btnStart = el("btn-start");
  const btnPause = el("btn-pause");
  const btnReset = el("btn-reset");
  const btnSkip = el("btn-skip");
  const inputWork = el("setting-work");
  const inputBreak = el("setting-break");
  const btnSave = el("btn-save-settings");

  // initialize inputs from loaded settings
  inputWork.value = workMinutes;
  inputBreak.value = breakMinutes;

  const formatTime = (s) => {
    const m = Math.floor(s / 60);
    const se = s % 60;
    return `${m}:${se < 10 ? "0" : ""}${se}`;
  };

  const updateDisplay = () => {
    timerDisplay.textContent = formatTime(remainingSeconds);
    phaseDisplay.textContent = phase;
    cycleDisplay.textContent = `Cycles: ${cycleCount}`;
  };

  const stopInterval = () => {
    if (intervalId !== null) {
      clearInterval(intervalId);
      intervalId = null;
    }
    running = false;
  };

  const tick = () => {
    if (remainingSeconds > 0) {
      remainingSeconds--;
      updateDisplay();
    }
    if (remainingSeconds === 0) {
      stopInterval();
      onPhaseComplete();
    }
  };

  const onPhaseComplete = () => {
    if (phase === "work") {
      phase = "break";
      remainingSeconds = breakMinutes * 60;
    } else {
      phase = "work";
      remainingSeconds = workMinutes * 60;
      cycleCount++;
      W.setItem("pomo_cycles", String(cycleCount));
    }
    updateDisplay();
    startTimer();
  };

  const startTimer = () => {
    if (running) return;
    running = true;
    intervalId = setInterval(tick, 1000);
  };

  const pauseTimer = () => stopInterval();

  const resetTimer = () => {
    stopInterval();
    remainingSeconds = (phase === "work" ? workMinutes : breakMinutes) * 60;
    updateDisplay();
  };

  const skipPhase = () => {
    stopInterval();
    if (phase === "work") {
      phase = "break";
      remainingSeconds = breakMinutes * 60;
    } else {
      phase = "work";
      remainingSeconds = workMinutes * 60;
      cycleCount++;
      W.setItem("pomo_cycles", String(cycleCount));
    }
    updateDisplay();
  };

  const saveSettings = () => {
    let w = parseInt(inputWork.value, 10);
    let b = parseInt(inputBreak.value, 10);
    if (isNaN(w) || w < 1) w = 25;
    if (isNaN(b) || b < 1) b = 5;
    workMinutes = w;
    breakMinutes = b;
    W.setItem("pomo_work", String(workMinutes));
    W.setItem("pomo_break", String(breakMinutes));
    inputWork.value = workMinutes;
    inputBreak.value = breakMinutes;
  };

  btnStart.addEventListener("click", startTimer);
  btnPause.addEventListener("click", pauseTimer);
  btnReset.addEventListener("click", resetTimer);
  btnSkip.addEventListener("click", skipPhase);
  btnSave.addEventListener("click", saveSettings);

  updateDisplay();
})();
</script>
</body>
</html>