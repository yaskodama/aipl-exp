<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Todo App</title>
<style>*{box-sizing:border-box}body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f4f6f8;margin:0;padding:20px;display:flex;justify-content:center}.app{background:#fff;width:100%;max-width:520px;border-radius:8px;box-shadow:0 2px 12px rgba(0,0,0,.08);padding:24px}h1{margin:0 0 16px;font-size:24px;color:#333}.input-row{display:flex;gap:8px;margin-bottom:16px}#new-todo-input{flex:1;padding:8px 12px;border:1px solid #ccc;border-radius:4px;font-size:16px}button{padding:8px 16px;border:1px solid #ccc;background:#fff;border-radius:4px;cursor:pointer;font-size:14px}button:hover{background:#f0f0f0}#add-btn{background:#4a90e2;color:#fff;border-color:#4a90e2}#add-btn:hover{background:#3a7fcf}.filters{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap}.filters button.active{background:#4a90e2;color:#fff;border-color:#4a90e2}ul{list-style:none;padding:0;margin:0 0 16px}li{display:flex;align-items:center;gap:8px;padding:10px 8px;border-bottom:1px solid #eee}li:last-child{border-bottom:none}.todo-text{flex:1;outline:none;padding:4px 6px;border-radius:3px}.todo-text[contenteditable="true"]{background:#fffbe6;border:1px solid #f0d050}li.completed .todo-text{text-decoration:line-through;color:#999}.todo-delete{background:#e74c3c;color:#fff;border-color:#e74c3c;padding:4px 10px;font-size:12px}.todo-delete:hover{background:#c0392b}.footer{display:flex;justify-content:flex-end}#clear-completed{font-size:13px}</style>
</head>
<body>
  <div class="app">
    <h1>Todo App</h1>
    <div class="input-row">
      <input type="text" data-testid="new-todo-input" id="new-todo-input" placeholder="新しいタスクを入力...">
      <button data-testid="add-btn" id="add-btn">追加</button>
    </div>
    <div class="filters">
      <button data-testid="filter-all" id="filter-all" class="active">全て</button>
      <button data-testid="filter-active" id="filter-active">未完了</button>
      <button data-testid="filter-completed" id="filter-completed">完了</button>
    </div>
    <ul data-testid="todo-list" id="todo-list"></ul>
    <div class="footer">
      <button data-testid="clear-completed" id="clear-completed">完了項目を削除</button>
    </div>
  </div>
<script>
(function(){
const KEY='single-html-todo-app';
let todos=[],filter='all';
const $id=(s)=>document.getElementById(s);
const $input=$id('new-todo-input'),$add=$id('add-btn'),$list=$id('todo-list'),$fa=$id('filter-all'),$fr=$id('filter-active'),$fc=$id('filter-completed'),$clear=$id('clear-completed');
function load(){try{const r=localStorage.getItem(KEY);todos=r?JSON.parse(r):[]}catch(e){todos=[]}}
function save(){try{localStorage.setItem(KEY,JSON.stringify(todos))}catch(e){}}
const uid=()=>Date.now().toString(36)+Math.random().toString(36).slice(2,7);
function add(text){text=(text||'').trim();if(!text) return;todos.push({id:uid(),text,completed:false});save();render()}
function del(id){todos=todos.filter(t=>t.id!==id);save();render()}
function tog(id){const t=todos.find(x=>x.id===id);if(t){t.completed=!t.completed;save();render()}}
function upd(id,txt){const t=todos.find(x=>x.id===id);if(t){t.text=txt.trim();if(!t.text){del(id);return}save()}}
function clearCompleted(){todos=todos.filter(t=>!t.completed);save();render()}
function setFilter(f){filter=f;[$fa,$fr,$fc].forEach(b=>b.classList.remove('active'));if(f==='all')$fa.classList.add('active');else if(f==='active')$fr.classList.add('active');else $fc.classList.add('active');render()}
function render(){
  $list.innerHTML='';
  todos.filter(t=>filter==='all'||(filter==='active'?!t.completed:t.completed)).forEach(t=>{
    const li=document.createElement('li');li.setAttribute('data-testid','todo-item');li.dataset.id=t.id;if(t.completed)li.classList.add('completed');
    const cb=document.createElement('input');cb.type='checkbox';cb.setAttribute('data-testid','todo-toggle');cb.checked=t.completed;cb.addEventListener('change',()=>tog(t.id));
    const sp=document.createElement('span');sp.setAttribute('data-testid','todo-text');sp.className='todo-text';sp.textContent=t.text;
    const startEdit=()=>{ if(sp.getAttribute('contenteditable')==='true') return; sp.setAttribute('contenteditable','true'); sp.focus(); try{ const r=document.createRange(); r.selectNodeContents(sp); r.collapse(false); const s=window.getSelection&&window.getSelection(); if(s){s.removeAllRanges(); s.addRange(r)} }catch(_){ } };
    sp.addEventListener('dblclick',startEdit);
    li.addEventListener('dblclick',(e)=>{ if(e.target===cb||e.target===db) return; startEdit(); });
    sp.addEventListener('blur',()=>{if(sp.getAttribute('contenteditable')==='true'){sp.removeAttribute('contenteditable');upd(t.id,sp.textContent);render()}});
    sp.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();sp.blur()}else if(e.key==='Escape'){e.preventDefault();sp.textContent=t.text;sp.blur()}});
    const db=document.createElement('button');db.setAttribute('data-testid','todo-delete');db.className='todo-delete';db.textContent='削除';db.addEventListener('click',()=>del(t.id));
    li.append(cb,sp,db);$list.appendChild(li);
  });
}
$add.addEventListener('click',()=>{add($input.value);$input.value='';$input.focus()});
$input.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();add($input.value);$input.value=''}});
$input.addEventListener('keyup',e=>{if(e.key==='Enter'){e.preventDefault();add($input.value);$input.value=''}});
$fa.addEventListener('click',()=>setFilter('all'));$fr.addEventListener('click',()=>setFilter('active'));$fc.addEventListener('click',()=>setFilter('completed'));$clear.addEventListener('click',clearCompleted);
load();render();
})();
</script>
</body>
</html>