<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Todo App</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, sans-serif; background: #f5f5f5; display: flex; justify-content: center; padding: 40px 16px; }
  .container { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15); width: 100%; max-width: 640px; padding: 24px; }
  h1 { text-align: center; margin-bottom: 20px; color: #333; }
  .input-row { display: flex; gap: 8px; margin-bottom: 16px; }
  [data-testid="new-todo-input"] { flex: 1; padding: 10px 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 15px; outline: none; }
  [data-testid="new-todo-input"]:focus { border-color: #4a90e2; }
  button { cursor: pointer; border: none; border-radius: 4px; padding: 10px 14px; font-size: 14px; }
  [data-testid="add-btn"] { background: #4a90e2; color: #fff; }
  [data-testid="add-btn"]:hover { background: #357abd; }
  .filters { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; justify-content: center; }
  .filters button { background: #eee; color: #333; }
  .filters button.active { background: #4a90e2; color: #fff; }
  [data-testid="todo-list"] { list-style: none; margin-bottom: 16px; padding-left: 0; }
  [data-testid="todo-item"] { display: flex; align-items: center; gap: 8px; padding: 10px 8px; border-bottom: 1px solid #eee; }
  [data-testid="todo-item"]:last-child { border-bottom: none; }
  [data-testid="todo-toggle"] { width: 18px; height: 18px; cursor: pointer; flex-shrink: 0; }
  [data-testid="todo-text"] { flex: 1; font-size: 15px; word-break: break-word; outline: none; padding: 4px; }
  [data-testid="todo-text"].completed { text-decoration: line-through; color: #aaa; }
  /* from parent B */ 
  [data-testid="todo-text"][contenteditable="true"] { background: #ffffe0; outline: 1px solid #4a90e2; }
  [data-testid="todo-delete"] { background: #e74c3c; color: #fff; padding: 6px 10px; font-size: 13px; flex-shrink: 0; }
  [data-testid="todo-delete"]:hover { background: #c0392b; }
  .bottom-bar { display: flex; justify-content: flex-end; }
  [data-testid="clear-completed"] { background: #e67e22; color: #fff; padding: 8px 12px; border-radius: 4px; }
  [data-testid="clear-completed"]:hover { background: #ca6f1e; }
  [data-testid="todo-item"].hidden { display: none; }
  /* subtle responsive */
  @media (max-width:420px){
    .container{padding:16px;}
    button{padding:8px 10px;font-size:13px;}
  }
</style>
</head>
<body>
  <div class="container">
    <h1>Todo</h1>
    <div class="input-row">
      <input type="text" data-testid="new-todo-input" placeholder="新しいタスクを入力..." />
      <button data-testid="add-btn">追加</button>
    </div>

    <div class="filters">
      <button data-testid="filter-all" id="filter-all">全て</button>
      <button data-testid="filter-active" id="filter-active">未完了</button>
      <button data-testid="filter-completed" id="filter-completed">完了</button>
    </div>

    <ul data-testid="todo-list" id="todo-list"></ul>

    <div class="bottom-bar">
      <button data-testid="clear-completed" id="clear-completed">完了を一括削除</button>
    </div>
  </div>

<script>
/*
  Merged implementation combining strengths of Parent A and Parent B.
  Relevant origins marked with comments like: // from parent A or // from parent B
*/

(function(){
  // storage keys
  const STORAGE_KEY = 'todo-app-items'; // from parent A (same name)
  const FILTER_KEY = 'todo-app-filter'; // from parent B (persist filter)

  // state
  let todos = []; // {id, text, completed}
  let filter = 'all';

  // elements
  const input = document.querySelector('[data-testid="new-todo-input"]'); // from parent A
  const addBtn = document.querySelector('[data-testid="add-btn"]'); // from parent A
  const listEl = document.querySelector('[data-testid="todo-list"]'); // from both
  const filterAll = document.querySelector('[data-testid="filter-all"]'); // from parent B
  const filterActive = document.querySelector('[data-testid="filter-active"]'); // from parent B
  const filterCompleted = document.querySelector('[data-testid="filter-completed"]'); // from parent B
  const clearCompletedBtn = document.querySelector('[data-testid="clear-completed"]'); // from parent B

  // load from localStorage
  function load() {
    // from parent B: try/catch load pattern and load filter too
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      todos = raw ? JSON.parse(raw) : [];
    } catch(e) {
      todos = [];
    }
    filter = localStorage.getItem(FILTER_KEY) || 'all';
  }

  // save to localStorage
  function save() {
    // from parent A/B: save todos; B also saves filter
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
      localStorage.setItem(FILTER_KEY, filter);
    } catch(e) {
      // ignore quota errors silently
    }
  }

  // generate id robustly (from parent B)
  function genId() {
    // from parent B
    return Date.now() + Math.random();
  }

  // add new todo
  function add(text) {
    // from parent B (trim and ignore empty)
    text = (text || '').trim();
    if (!text) return;
    todos.push({ id: genId(), text: text, completed: false });
    sync();
  }

  // delete todo by id
  function del(id) {
    // from parent A/B: filtering out id
    todos = todos.filter(t => t.id !== id);
    sync();
  }

  // toggle completed
  function tog(id) {
    // from parent A: find and toggle
    const t = todos.find(x => x.id === id);
    if (t) {
      t.completed = !t.completed;
      sync();
    }
  }

  // update todo text
  function upd(id, newText) {
    // from parent A/B: trim, ignore empty changes
    const t = todos.find(x => x.id === id);
    if (!t) return;
    const trimmed = (newText || '').trim();
    if (trimmed) {
      t.text = trimmed;
      save(); // persist change immediately
    } else {
      // if empty, do not apply; keep existing text (from parent A)
    }
  }

  // clear completed todos
  function clearCompleted() {
    // from parent B
    todos = todos.filter(t => !t.completed);
    sync();
  }

  // set filter and persist (from parent B)
  function setFilter(f) {
    filter = f;
    sync();
  }

  // render list based on filter
  function render() {
    // from parent B: filter before render
    listEl.innerHTML = '';
    const filtered = todos.filter(t => {
      if (filter === 'active') return !t.completed;
      if (filter === 'completed') return t.completed;
      return true;
    });

    filtered.forEach(t => {
      const li = document.createElement('li');
      li.setAttribute('data-testid', 'todo-item'); // required by tests
      li.dataset.id = t.id;

      if (t.completed) li.classList.add('completed'); // style hook (some CSS target li.completed)

      // checkbox
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.setAttribute('data-testid', 'todo-toggle'); // from spec and both parents
      cb.checked = !!t.completed;
      cb.addEventListener('change', () => tog(t.id)); // from both

      // text element (span)
      const span = document.createElement('span');
      span.setAttribute('data-testid', 'todo-text'); // from spec
      span.className = 'todo-text';
      span.textContent = t.text;
      if (t.completed) span.classList.add('completed'); // from parent A

      // double click to edit: combine parent A (select all) and B (cursor placement)
      span.addEventListener('dblclick', () => {
        // from parent A: make content editable and select contents
        span.setAttribute('contenteditable', 'true');
        span.focus();
        try {
          // attempt to select contents (from parent A) and then place cursor at end (from parent B)
          const range = document.createRange();
          range.selectNodeContents(span);
          // collapse to end to place cursor at end (from parent B)
          range.collapse(false);
          const sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(range);
        } catch (e) {
          // ignore selection errors
        }
      });

      // blur to save
      span.addEventListener('blur', () => {
        if (span.getAttribute('contenteditable') === 'true') {
          span.setAttribute('contenteditable', 'false');
          // from parent A/B: update, but preserve old if new empty
          const before = t.text;
          upd(t.id, span.textContent);
          // if update didn't change because empty, restore visible text
          const after = todos.find(x => x.id === t.id);
          if (after) {
            span.textContent = after.text;
          } else {
            span.textContent = before;
          }
          // reflect completion styling if needed
          if (t.completed) span.classList.add('completed'); else span.classList.remove('completed');
        }
      });

      // keyboard handling during edit
      span.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          // from parent A/B: prevent newline and blur to save
          e.preventDefault();
          span.blur();
        } else if (e.key === 'Escape') {
          // from parent B: revert changes and blur
          span.textContent = t.text;
          span.blur();
        }
      });

      // delete button
      const delBtn = document.createElement('button');
      delBtn.setAttribute('data-testid', 'todo-delete'); // from spec
      delBtn.textContent = '削除';
      delBtn.addEventListener('click', () => del(t.id)); // from both
      // small accessibility hint - not required by tests, safe to include
      delBtn.setAttribute('aria-label', '削除');

      li.appendChild(cb);
      li.appendChild(span);
      li.appendChild(delBtn);
      listEl.appendChild(li);
    });

    // update filter buttons active state (from parent B)
    [ ['all', filterAll], ['active', filterActive], ['completed', filterCompleted] ].forEach(([name, btn]) => {
      if (!btn) return;
      btn.classList.toggle('active', filter === name);
    });
  }

  // sync: save and render (from parent B's sync pattern)
  function sync() {
    save();
    render();
  }

  // event wiring
  addBtn.addEventListener('click', () => {
    // from parent A: add from input and clear+focus
    add(input.value);
    input.value = '';
    input.focus();
  });

  input.addEventListener('keydown', (e) => {
    // from parent A/B: Enter to add
    if (e.key === 'Enter') {
      add(e.target.value);
      e.target.value = '';
    }
  });

  filterAll && filterAll.addEventListener('click', () => setFilter('all')); // from parent B
  filterActive && filterActive.addEventListener('click', () => setFilter('active')); // from parent B
  filterCompleted && filterCompleted.addEventListener('click', () => setFilter('completed')); // from parent B

  clearCompletedBtn && clearCompletedBtn.addEventListener('click', clearCompleted); // from parent B

  // initialize
  load(); // from parent B/A
  sync(); // from parent B
})();
</script>
</body>
</html>