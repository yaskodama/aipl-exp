<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Pomodoro Timer</title>
<style>
  body { font-family: sans-serif; max-width: 480px; margin: 20px auto; padding: 20px; background: #f5f5f5; }
  h1 { text-align: center; }
  .display { text-align: center; padding: 20px; background: white; border-radius: 8px; margin-bottom: 16px; }
  .timer { font-size: 64px; font-weight: bold; font-family: monospace; }
  .phase { font-size: 24px; margin: 8px 0; text-transform: uppercase; color: #555; }
  .cycle { font-size: 18px; color: #777; }
  .controls, .settings { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 16px; }
  button { padding: 10px 16px; font-size: 16px; cursor: pointer; border: 1px solid #ccc; background: white; border-radius: 4px; }
  button:hover { background: #eee; }
  .settings { background: white; padding: 16px; border-radius: 8px; }
  .settings label { display: flex; align-items: center; gap: 8px; }
  .settings input { width: 60px; padding: 4px; }
</style>
</head>
<body>
  <h1>Pomodoro Timer</h1>
  <div class="display">
    <div class="timer" data-testid="timer-display">25:00</div>
    <div class="phase" data-testid="phase-display">work</div>
    <div class="cycle">Cycle: <span data-testid="cycle-count">0</span></div>
  </div>

  <div class="controls">
    <button data-testid="btn-start">Start</button>
    <button data-testid="btn-pause">Pause</button>
    <button data-testid="btn-reset">Reset</button>
    <button data-testid="btn-skip">Skip</button>
  </div>

  <div class="settings">
    <label>Work (min): <input type="number" data-testid="setting-work" value="25" min="1"></label>
    <label>Break (min): <input type="number" data-testid="setting-break" value="5" min="1"></label>
    <button data-testid="btn-save-settings">Save</button>
  </div>

<script>
(function() {
  const STORAGE_KEY = 'pomodoro_state_v1';

  const timerEl = document.querySelector('[data-testid="timer-display"]');
  const phaseEl = document.querySelector('[data-testid="phase-display"]');
  const cycleEl = document.querySelector('[data-testid="cycle-count"]');
  const startBtn = document.querySelector('[data-testid="btn-start"]');
  const pauseBtn = document.querySelector('[data-testid="btn-pause"]');
  const resetBtn = document.querySelector('[data-testid="btn-reset"]');
  const skipBtn = document.querySelector('[data-testid="btn-skip"]');
  const workInput = document.querySelector('[data-testid="setting-work"]');
  const breakInput = document.querySelector('[data-testid="setting-break"]');
  const saveBtn = document.querySelector('[data-testid="btn-save-settings"]');

  // Load persisted state
  let saved = {};
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) saved = JSON.parse(raw) || {};
  } catch(e) { saved = {}; }

  let workMinutes = (typeof saved.workMinutes === 'number' && saved.workMinutes > 0) ? saved.workMinutes : 25;
  let breakMinutes = (typeof saved.breakMinutes === 'number' && saved.breakMinutes > 0) ? saved.breakMinutes : 5;
  let cycleCount = (typeof saved.cycleCount === 'number') ? saved.cycleCount : 0;

  workInput.value = workMinutes;
  breakInput.value = breakMinutes;

  let phase = 'work';
  let remaining = workMinutes * 60; // seconds
  let intervalId = null;

  function persist() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        workMinutes: workMinutes,
        breakMinutes: breakMinutes,
        cycleCount: cycleCount
      }));
    } catch(e) {}
  }

  function formatTime(sec) {
    if (sec < 0) sec = 0;
    const m = Math.floor(sec / 60);
    const s = sec % 60;
    return m + ':' + (s < 10 ? '0' + s : s);
  }

  function render() {
    timerEl.textContent = formatTime(remaining);
    phaseEl.textContent = phase;
    cycleEl.textContent = cycleCount;
  }

  function phaseDurationSec(p) {
    return (p === 'work' ? workMinutes : breakMinutes) * 60;
  }

  function tick() {
    remaining -= 1;
    if (remaining <= 0) {
      // Phase complete
      if (phase === 'work') {
        phase = 'break';
        remaining = phaseDurationSec('break');
      } else {
        phase = 'work';
        cycleCount += 1;
        persist();
        remaining = phaseDurationSec('work');
      }
    }
    render();
  }

  function start() {
    if (intervalId !== null) return;
    intervalId = setInterval(tick, 1000);
  }

  function pause() {
    if (intervalId !== null) {
      clearInterval(intervalId);
      intervalId = null;
    }
  }

  function reset() {
    pause();
    remaining = phaseDurationSec(phase);
    render();
  }

  function skip() {
    pause();
    if (phase === 'work') {
      phase = 'break';
    } else {
      phase = 'work';
      cycleCount += 1;
      persist();
    }
    remaining = phaseDurationSec(phase);
    render();
  }

  function saveSettings() {
    const w = parseInt(workInput.value, 10);
    const b = parseInt(breakInput.value, 10);
    if (!isNaN(w) && w > 0) workMinutes = w;
    if (!isNaN(b) && b > 0) breakMinutes = b;
    persist();
  }

  startBtn.addEventListener('click', start);
  pauseBtn.addEventListener('click', pause);
  resetBtn.addEventListener('click', reset);
  skipBtn.addEventListener('click', skip);
  saveBtn.addEventListener('click', saveSettings);

  render();
})();
</script>
</body>
</html>