<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo App</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            width: 100%;
            max-width: 600px;
            padding: 30px;
        }

        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 30px;
            font-size: 32px;
        }

        .input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        input[data-testid="new-todo-input"] {
            flex: 1;
            padding: 12px 16px;
            border: 2px solid #ddd;
            border-radius: 6px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        input[data-testid="new-todo-input"]:focus {
            outline: none;
            border-color: #667eea;
        }

        button[data-testid="add-btn"] {
            padding: 12px 24px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
        }

        button[data-testid="add-btn"]:hover {
            background: #5568d3;
        }

        button[data-testid="add-btn"]:active {
            transform: scale(0.98);
        }

        .filters {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 8px 16px;
            border: 2px solid #ddd;
            background: white;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s;
        }

        .filter-btn.active {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }

        .filter-btn:hover {
            border-color: #667eea;
        }

        ul[data-testid="todo-list"] {
            list-style: none;
            margin-bottom: 20px;
        }

        li[data-testid="todo-item"] {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: #f9f9f9;
            border-radius: 6px;
            margin-bottom: 8px;
            transition: all 0.3s;
        }

        li[data-testid="todo-item"]:hover {
            background: #f0f0f0;
        }

        input[type="checkbox"][data-testid="todo-toggle"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            flex-shrink: 0;
        }

        span[data-testid="todo-text"] {
            flex: 1;
            word-break: break-word;
            cursor: text;
            padding: 4px;
            border-radius: 4px;
        }

        li[data-testid="todo-item"].completed span[data-testid="todo-text"] {
            text-decoration: line-through;
            color: #999;
        }

        span[data-testid="todo-text"].editing {
            background: white;
            border: 1px solid #667eea;
            padding: 8px;
            outline: none;
        }

        button[data-testid="todo-delete"] {
            padding: 6px 12px;
            background: #ff6b6b;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: background 0.3s;
            flex-shrink: 0;
        }

        button[data-testid="todo-delete"]:hover {
            background: #ff5252;
        }

        button[data-testid="clear-completed"] {
            display: block;
            margin: 0 auto;
            padding: 10px 20px;
            background: #ff6b6b;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            transition: background 0.3s;
        }

        button[data-testid="clear-completed"]:hover {
            background: #ff5252;
        }

        button[data-testid="clear-completed"]:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        .empty-state {
            text-align: center;
            color: #999;
            padding: 40px 20px;
            font-size: 16px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📝 Todo App</h1>

        <div class="input-group">
            <input
                type="text"
                data-testid="new-todo-input"
                placeholder="新しいタスクを入力..."
                autocomplete="off"
            >
            <button data-testid="add-btn">追加</button>
        </div>

        <div class="filters">
            <button class="filter-btn active" data-testid="filter-all">全て</button>
            <button class="filter-btn" data-testid="filter-active">未完了</button>
            <button class="filter-btn" data-testid="filter-completed">完了</button>
        </div>

        <ul data-testid="todo-list"></ul>

        <div class="empty-state" id="empty-state">タスクはまだありません</div>

        <button data-testid="clear-completed">完了済みを削除</button>
    </div>

    <script>
        const INPUT = document.querySelector('[data-testid="new-todo-input"]');
        const ADD_BTN = document.querySelector('[data-testid="add-btn"]');
        const TODO_LIST = document.querySelector('[data-testid="todo-list"]');
        const FILTER_ALL = document.querySelector('[data-testid="filter-all"]');
        const FILTER_ACTIVE = document.querySelector('[data-testid="filter-active"]');
        const FILTER_COMPLETED = document.querySelector('[data-testid="filter-completed"]');
        const CLEAR_COMPLETED = document.querySelector('[data-testid="clear-completed"]');
        const EMPTY_STATE = document.getElementById('empty-state');

        let todos = [];
        let currentFilter = 'all';
        const STORAGE_KEY = 'todos';

        function loadTodos() {
            const stored = localStorage.getItem(STORAGE_KEY);
            todos = stored ? JSON.parse(stored) : [];
        }

        function saveTodos() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
        }

        function addTodo(text) {
            if (!text.trim()) return;
            const todo = {
                id: Date.now(),
                text: text.trim(),
                completed: false
            };
            todos.push(todo);
            saveTodos();
            render();
        }

        function deleteTodo(id) {
            todos = todos.filter(t => t.id !== id);
            saveTodos();
            render();
        }

        function toggleTodo(id) {
            const todo = todos.find(t => t.id === id);
            if (todo) {
                todo.completed = !todo.completed;
                saveTodos();
                render();
            }
        }

        function updateTodoText(id, newText) {
            const todo = todos.find(t => t.id === id);
            if (todo) {
                todo.text = newText.trim() || todo.text;
                saveTodos();
                render();
            }
        }

        function clearCompleted() {
            todos = todos.filter(t => !t.completed);
            saveTodos();
            render();
        }

        function getFilteredTodos() {
            switch (currentFilter) {
                case 'active':
                    return todos.filter(t => !t.completed);
                case 'completed':
                    return todos.filter(t => t.completed);
                default:
                    return todos;
            }
        }

        function render() {
            const filtered = getFilteredTodos();
            TODO_LIST.innerHTML = '';

            if (filtered.length === 0) {
                EMPTY_STATE.style.display = 'block';
            } else {
                EMPTY_STATE.style.display = 'none';
            }

            filtered.forEach(todo => {
                const li = document.createElement('li');
                li.setAttribute('data-testid', 'todo-item');
                li.className = todo.completed ? 'completed' : '';

                const checkbox = document.createElement('input');
                checkbox.type = 'checkbox';
                checkbox.setAttribute('data-testid', 'todo-toggle');
                checkbox.checked = todo.completed;
                checkbox.addEventListener('change', () => toggleTodo(todo.id));

                const span = document.createElement('span');
                span.setAttribute('data-testid', 'todo-text');
                span.textContent = todo.text;
                span.addEventListener('dblclick', () => {
                    enterEditMode(span, todo.id);
                });

                const deleteBtn = document.createElement('button');
                deleteBtn.setAttribute('data-testid', 'todo-delete');
                deleteBtn.textContent = '削除';
                deleteBtn.addEventListener('click', () => deleteTodo(todo.id));

                li.appendChild(checkbox);
                li.appendChild(span);
                li.appendChild(deleteBtn);
                TODO_LIST.appendChild(li);
            });

            const hasCompleted = todos.some(t => t.completed);
            CLEAR_COMPLETED.disabled = !hasCompleted;
        }

        function enterEditMode(span, todoId) {
            const originalText = span.textContent;
            span.contentEditable = true;
            span.className = 'editing';
            span.focus();

            const selectAll = () => {
                const range = document.createRange();
                range.selectNodeContents(span);
                const sel = window.getSelection();
                sel.removeAllRanges();
                sel.addRange(range);
            };
            selectAll();

            function exitEditMode() {
                const newText = span.textContent;
                span.contentEditable = false;
                span.className = '';
                if (newText.trim()) {
                    updateTodoText(todoId, newText);
                } else {
                    span.textContent = originalText;
                }
            }

            span.addEventListener('blur', exitEditMode, { once: true });
            span.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    exitEditMode();
                } else if (e.key === 'Escape') {
                    e.preventDefault();
                    span.textContent = originalText;
                    exitEditMode();
                }
            }, { once: true });
        }

        ADD_BTN.addEventListener('click', () => {
            addTodo(INPUT.value);
            INPUT.value = '';
        });

        INPUT.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                addTodo(INPUT.value);
                INPUT.value = '';
            }
        });

        FILTER_ALL.addEventListener('click', () => {
            currentFilter = 'all';
            updateFilterButtons();
            render();
        });

        FILTER_ACTIVE.addEventListener('click', () => {
            currentFilter = 'active';
            updateFilterButtons();
            render();
        });

        FILTER_COMPLETED.addEventListener('click', () => {
            currentFilter = 'completed';
            updateFilterButtons();
            render();
        });

        CLEAR_COMPLETED.addEventListener('click', clearCompleted);

        function updateFilterButtons() {
            const allBtn = document.querySelector('[data-testid="filter-all"]');
            const activeBtn = document.querySelector('[data-testid="filter-active"]');
            const completedBtn = document.querySelector('[data-testid="filter-completed"]');

            allBtn.classList.remove('active');
            activeBtn.classList.remove('active');
            completedBtn.classList.remove('active');

            if (currentFilter === 'all') allBtn.classList.add('active');
            if (currentFilter === 'active') activeBtn.classList.add('active');
            if (currentFilter === 'completed') completedBtn.classList.add('active');
        }

        loadTodos();
        render();
    </script>
</body>
</html>