<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Todo App</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, sans-serif;
      background: #f0f2f5;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      padding: 40px 16px;
    }

    .container {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.1);
      padding: 32px;
      width: 100%;
      max-width: 560px;
      height: fit-content;
    }

    h1 {
      text-align: center;
      margin-bottom: 24px;
      color: #333;
    }

    .input-row {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
    }

    input[data-testid="new-todo-input"] {
      flex: 1;
      padding: 10px 14px;
      border: 1px solid #ccc;
      border-radius: 4px;
      font-size: 15px;
      outline: none;
      transition: border-color 0.2s;
    }

    input[data-testid="new-todo-input"]:focus {
      border-color: #4a90e2;
    }

    button[data-testid="add-btn"] {
      padding: 10px 18px;
      background: #4a90e2;
      color: #fff;
      border: none;
      border-radius: 4px;
      font-size: 15px;
      cursor: pointer;
      transition: background 0.2s;
    }

    button[data-testid="add-btn"]:hover {
      background: #357abd;
    }

    .filter-row {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .filter-row button {
      padding: 6px 14px;
      border: 1px solid #ccc;
      background: #fff;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      transition: background 0.2s, border-color 0.2s;
    }

    .filter-row button.active {
      background: #4a90e2;
      color: #fff;
      border-color: #4a90e2;
    }

    .filter-row button:hover:not(.active) {
      background: #f0f2f5;
    }

    ul[data-testid="todo-list"] {
      list-style: none;
      margin-bottom: 16px;
    }

    li[data-testid="todo-item"] {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 8px;
      border-bottom: 1px solid #eee;
      transition: background 0.15s;
    }

    li[data-testid="todo-item"]:hover {
      background: #fafafa;
    }

    li[data-testid="todo-item"].hidden {
      display: none;
    }

    input[data-testid="todo-toggle"] {
      width: 18px;
      height: 18px;
      cursor: pointer;
      flex-shrink: 0;
    }

    span[data-testid="todo-text"] {
      flex: 1;
      font-size: 15px;
      color: #333;
      word-break: break-word;
      cursor: text;
    }

    span[data-testid="todo-text"].completed {
      text-decoration: line-through;
      color: #aaa;
    }

    span[data-testid="todo-text"][contenteditable="true"] {
      outline: 1px solid #4a90e2;
      border-radius: 2px;
      padding: 2px 4px;
      background: #fff;
    }

    button[data-testid="todo-delete"] {
      padding: 4px 10px;
      background: #e74c3c;
      color: #fff;
      border: none;
      border-radius: 4px;
      font-size: 13px;
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.2s;
    }

    button[data-testid="todo-delete"]:hover {
      background: #c0392b;
    }

    .footer-row {
      display: flex;
      justify-content: flex-end;
    }

    button[data-testid="clear-completed"] {
      padding: 7px 14px;
      background: #e67e22;
      color: #fff;
      border: none;
      border-radius: 4px;
      font-size: 13px;
      cursor: pointer;
      transition: background 0.2s;
    }

    button[data-testid="clear-completed"]:hover {
      background: #ca6f1e;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Todo</h1>
    <div class="input-row">
      <input type="text" data-testid="new-todo-input" placeholder="新しいタスクを入力...">
      <button data-testid="add-btn">追加</button>
    </div>
    <div class="filter-row">
      <button data-testid="filter-all" class="active">全て</button>
      <button data-testid="filter-active">未完了</button>
      <button data-testid="filter-completed">完了</button>
    </div>
    <ul data-testid="todo-list"></ul>
    <div class="footer-row">
      <button data-testid="clear-completed">完了項目を一括削除</button>
    </div>
  </div>

  <script>
    (function () {
      const STORAGE_KEY = 'todo-app-items';

      let todos = [];
      let currentFilter = 'all';

      const input = document.querySelector('[data-testid="new-todo-input"]');
      const addBtn = document.querySelector('[data-testid="add-btn"]');
      const list = document.querySelector('[data-testid="todo-list"]');
      const filterAll = document.querySelector('[data-testid="filter-all"]');
      const filterActive = document.querySelector('[data-testid="filter-active"]');
      const filterCompleted = document.querySelector('[data-testid="filter-completed"]');
      const clearCompletedBtn = document.querySelector('[data-testid="clear-completed"]');

      function loadFromStorage() {
        try {
          const data = localStorage.getItem(STORAGE_KEY);
          if (data) {
            todos = JSON.parse(data);
          }
        } catch (e) {
          todos = [];
        }
      }

      function saveToStorage() {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
        } catch (e) {}
      }

      function generateId() {
        return Date.now().toString(36) + Math.random().toString(36).slice(2);
      }

      function addTodo(text) {
        const trimmed = text.trim();
        if (!trimmed) return;
        todos.push({ id: generateId(), text: trimmed, completed: false });
        saveToStorage();
        render();
      }

      function deleteTodo(id) {
        todos = todos.filter(t => t.id !== id);
        saveToStorage();
        render();
      }

      function toggleTodo(id) {
        const todo = todos.find(t => t.id === id);
        if (todo) {
          todo.completed = !todo.completed;
          saveToStorage();
          render();
        }
      }

      function updateTodoText(id, newText) {
        const trimmed = newText.trim();
        const todo = todos.find(t => t.id === id);
        if (todo) {
          if (trimmed) {
            todo.text = trimmed;
          }
          saveToStorage();
        }
      }

      function clearCompleted() {
        todos = todos.filter(t => !t.completed);
        saveToStorage();
        render();
      }

      function isVisible(todo) {
        if (currentFilter === 'all') return true;
        if (currentFilter === 'active') return !todo.completed;
        if (currentFilter === 'completed') return todo.completed;
        return true;
      }

      function render() {
        list.innerHTML = '';

        todos.forEach(todo => {
          const li = document.createElement('li');
          li.setAttribute('data-testid', 'todo-item');
          li.setAttribute('data-id', todo.id);

          if (!isVisible(todo)) {
            li.classList.add('hidden');
          }

          const checkbox = document.createElement('input');
          checkbox.type = 'checkbox';
          checkbox.setAttribute('data-testid', 'todo-toggle');
          checkbox.checked = todo.completed;
          checkbox.addEventListener('change', () => toggleTodo(todo.id));

          const textSpan = document.createElement('span');
          textSpan.setAttribute('data-testid', 'todo-text');
          textSpan.textContent = todo.text;
          if (todo.completed) {
            textSpan.classList.add('completed');
          }

          textSpan.addEventListener('dblclick', () => {
            textSpan.setAttribute('contenteditable', 'true');
            textSpan.focus();
            const range = document.createRange();
            range.selectNodeContents(textSpan);
            const sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(range);
          });

          textSpan.addEventListener('blur', () => {
            textSpan.removeAttribute('contenteditable');
            const newText = textSpan.textContent.trim();
            if (newText) {
              updateTodoText(todo.id, newText);
              textSpan.textContent = newText;
            } else {
              textSpan.textContent = todo.text;
            }
            saveToStorage();
          });

          textSpan.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
              e.preventDefault();
              textSpan.blur();
            }
            if (e.key === 'Escape') {
              textSpan.textContent = todo.text;
              textSpan.removeAttribute('contenteditable');
            }
          });

          const deleteBtn = document.createElement('button');
          deleteBtn.setAttribute('data-testid', 'todo-delete');
          deleteBtn.textContent = '削除';
          deleteBtn.addEventListener('click', () => deleteTodo(todo.id));

          li.appendChild(checkbox);
          li.appendChild(textSpan);
          li.appendChild(deleteBtn);
          list.appendChild(li);
        });

        updateFilterButtons();
      }

      function updateFilterButtons() {
        filterAll.classList.toggle('active', currentFilter === 'all');
        filterActive.classList.toggle('active', currentFilter === 'active');
        filterCompleted.classList.toggle('active', currentFilter === 'completed');
      }

      function setFilter(filter) {
        currentFilter = filter;
        render();
      }

      addBtn.addEventListener('click', () => {
        addTodo(input.value);
        input.value = '';
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          addTodo(input.value);
          input.value = '';
        }
      });

      filterAll.addEventListener('click', () => setFilter('all'));
      filterActive.addEventListener('click', () => setFilter('active'));
      filterCompleted.addEventListener('click', () => setFilter('completed'));
      clearCompletedBtn.addEventListener('click', clearCompleted);

      loadFromStorage();
      render();
    })();
  </script>
</body>
</html>