<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Todo App</title>
<style>
  body { font-family: sans-serif; max-width: 600px; margin: 2em auto; padding: 1em; }
  h1 { text-align: center; }
  .input-row { display: flex; gap: .5em; margin-bottom: 1em; }
  #new-todo-input { flex: 1; padding: .5em; font-size: 1em; }
  button { padding: .5em 1em; cursor: pointer; }
  .filters { display: flex; gap: .5em; margin-bottom: 1em; justify-content: center; }
  .filters button.active { background: #4a90e2; color: white; }
  ul { list-style: none; padding: 0; }
  li { display: flex; align-items: center; gap: .5em; padding: .5em; border-bottom: 1px solid #eee; }
  li .todo-text { flex: 1; }
  li.completed .todo-text { text-decoration: line-through; color: #888; }
  li .todo-text[contenteditable="true"] { background: #fffbe6; outline: 1px dashed #f5c000; padding: 2px; }
  .clear-row { text-align: center; margin-top: 1em; }
</style>
</head>
<body>
<h1>Todo</h1>
<div class="input-row">
  <input type="text" data-testid="new-todo-input" id="new-todo-input" placeholder="何をしますか？">
  <button data-testid="add-btn" id="add-btn">追加</button>
</div>
<div class="filters">
  <button data-testid="filter-all" id="filter-all" class="active">全て</button>
  <button data-testid="filter-active" id="filter-active">未完了</button>
  <button data-testid="filter-completed" id="filter-completed">完了</button>
</div>
<ul data-testid="todo-list" id="todo-list"></ul>
<div class="clear-row">
  <button data-testid="clear-completed" id="clear-completed">完了項目を削除</button>
</div>

<script>
(function(){
  const STORAGE_KEY = 'todo-app-data-v1';
  const FILTER_KEY = 'todo-app-filter-v1';
  let todos = [];
  let filter = 'all';

  function load() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) todos = JSON.parse(raw) || [];
      const f = localStorage.getItem(FILTER_KEY);
      if (f) filter = f;
    } catch(e) { todos = []; }
  }

  function save() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
      localStorage.setItem(FILTER_KEY, filter);
    } catch(e) {}
  }

  function sync() {
    save();
    render();
  }

  function add(text) {
    text = (text || '').trim();
    if (!text) return;
    todos.push({ id: Date.now() + Math.random(), text: text, completed: false });
    sync();
  }

  function del(id) {
    todos = todos.filter(t => t.id !== id);
    sync();
  }

  function tog(id) {
    const t = todos.find(t => t.id === id);
    if (t) { t.completed = !t.completed; sync(); }
  }

  function upd(id, text) {
    const t = todos.find(t => t.id === id);
    if (!t) return;
    text = (text || '').trim();
    if (!text) { del(id); return; }
    t.text = text;
    sync();
  }

  function clearCompleted() {
    todos = todos.filter(t => !t.completed);
    sync();
  }

  function setFilter(f) {
    filter = f;
    sync();
  }

  function getVisible() {
    if (filter === 'active') return todos.filter(t => !t.completed);
    if (filter === 'completed') return todos.filter(t => t.completed);
    return todos;
  }

  function render() {
    const list = document.getElementById('todo-list');
    list.innerHTML = '';
    getVisible().forEach(t => {
      const li = document.createElement('li');
      li.setAttribute('data-testid', 'todo-item');
      li.dataset.id = t.id;
      if (t.completed) li.classList.add('completed');

      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.setAttribute('data-testid', 'todo-toggle');
      cb.checked = t.completed;
      cb.addEventListener('change', () => tog(t.id));

      const span = document.createElement('span');
      span.setAttribute('data-testid', 'todo-text');
      span.className = 'todo-text';
      span.textContent = t.text;
      span.addEventListener('dblclick', () => {
        span.contentEditable = 'true';
        li.contentEditable = 'true';
        span.focus();
        const range = document.createRange();
        range.selectNodeContents(span);
        const sel = window.getSelection();
        sel.removeAllRanges();
        sel.addRange(range);
      });
      span.addEventListener('blur', () => {
        span.contentEditable = 'false';
        li.contentEditable = 'false';
        upd(t.id, span.textContent);
      });
      span.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          span.blur();
        } else if (e.key === 'Escape') {
          e.preventDefault();
          span.textContent = t.text;
          span.blur();
        }
      });

      const delBtn = document.createElement('button');
      delBtn.setAttribute('data-testid', 'todo-delete');
      delBtn.textContent = '削除';
      delBtn.addEventListener('click', () => del(t.id));

      li.appendChild(cb);
      li.appendChild(span);
      li.appendChild(delBtn);
      list.appendChild(li);
    });

    ['all', 'active', 'completed'].forEach(f => {
      const btn = document.getElementById('filter-' + f);
      if (btn) btn.classList.toggle('active', filter === f);
    });
  }

  document.getElementById('add-btn').addEventListener('click', () => {
    const input = document.getElementById('new-todo-input');
    add(input.value);
    input.value = '';
    input.focus();
  });

  document.getElementById('new-todo-input').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const input = e.target;
      add(input.value);
      input.value = '';
    }
  });

  document.getElementById('filter-all').addEventListener('click', () => setFilter('all'));
  document.getElementById('filter-active').addEventListener('click', () => setFilter('active'));
  document.getElementById('filter-completed').addEventListener('click', () => setFilter('completed'));
  document.getElementById('clear-completed').addEventListener('click', clearCompleted);

  load();
  render();
})();
</script>
</body>
</html>