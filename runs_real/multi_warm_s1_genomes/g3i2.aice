<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Todo App</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: sans-serif; background: #f0f0f0; display: flex; justify-content: center; padding: 40px 16px; }
  .container { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.15); width: 100%; max-width: 520px; padding: 24px; }
  h1 { text-align: center; margin-bottom: 20px; color: #333; }
  .input-row { display: flex; gap: 8px; margin-bottom: 16px; }
  .input-row input { flex: 1; padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 15px; }
  .input-row button { padding: 8px 16px; background: #4a90e2; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 15px; }
  .input-row button:hover { background: #357abd; }
  .filters { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
  .filters button { padding: 6px 14px; border: 1px solid #ccc; border-radius: 4px; cursor: pointer; background: #fff; font-size: 14px; }
  .filters button.active { background: #4a90e2; color: #fff; border-color: #4a90e2; }
  ul[data-testid="todo-list"] { list-style: none; margin-bottom: 12px; }
  li[data-testid="todo-item"] { display: flex; align-items: center; gap: 8px; padding: 8px 4px; border-bottom: 1px solid #eee; }
  li[data-testid="todo-item"]:last-child { border-bottom: none; }
  [data-testid="todo-toggle"] { width: 18px; height: 18px; cursor: pointer; flex-shrink: 0; }
  [data-testid="todo-text"] { flex: 1; font-size: 15px; word-break: break-all; outline: none; }
  [data-testid="todo-text"].done { text-decoration: line-through; color: #999; }
  [data-testid="todo-text"][contenteditable="true"] { background: #fffbe6; border-radius: 3px; padding: 2px 4px; border: 1px solid #f0c040; }
  [data-testid="todo-delete"] { padding: 4px 10px; background: #e74c3c; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; flex-shrink: 0; }
  [data-testid="todo-delete"]:hover { background: #c0392b; }
  .footer { display: flex; justify-content: flex-end; }
  [data-testid="clear-completed"] { padding: 6px 14px; background: #e0e0e0; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; }
  [data-testid="clear-completed"]:hover { background: #c8c8c8; }
</style>
</head>
<body>
<div class="container">
  <h1>Todo</h1>
  <div class="input-row">
    <input data-testid="new-todo-input" type="text" placeholder="新しいタスクを入力..." aria-label="新しいタスク">
    <button data-testid="add-btn" aria-label="追加">追加</button>
  </div>
  <div class="filters" role="toolbar" aria-label="フィルタ">
    <button data-testid="filter-all" class="active">全て</button>
    <button data-testid="filter-active">未完了</button>
    <button data-testid="filter-completed">完了</button>
  </div>
  <ul data-testid="todo-list" aria-live="polite"></ul>
  <div class="footer">
    <button data-testid="clear-completed">完了を一括削除</button>
  </div>
</div>
<script>
  // from parent A: storage key and base state structure
  const STORAGE_KEY = 'todo_app_items';
  let todos = [];
  let filter = 'all';
  let nextId = 1;

  // from parent A: element references
  const input = document.querySelector('[data-testid="new-todo-input"]');
  const addBtn = document.querySelector('[data-testid="add-btn"]');
  const list = document.querySelector('[data-testid="todo-list"]');
  const filterAll = document.querySelector('[data-testid="filter-all"]');
  const filterActive = document.querySelector('[data-testid="filter-active"]');
  const filterCompleted = document.querySelector('[data-testid="filter-completed"]');
  const clearCompleted = document.querySelector('[data-testid="clear-completed"]');

  // from parent A: save to localStorage (keeps todos and nextId)
  function save() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ todos, nextId }));
    } catch (e) {
      console.warn('localStorage save failed', e);
    }
  }

  // from parent B: load from localStorage with safe parsing and nextId recovery
  function load() {
    try {
      const data = JSON.parse(localStorage.getItem(STORAGE_KEY));
      if (data && Array.isArray(data.todos)) {
        todos = data.todos;
        nextId = data.nextId || (todos.length ? Math.max(...todos.map(t => t.id)) + 1 : 1);
      }
    } catch (e) {
      // ignore corrupted storage
    }
  }

  // from parent B: add new todo (trim input, ignore empty)
  function add(text) {
    text = String(text || '').trim();
    if (!text) return;
    todos.push({ id: nextId++, text, done: false });
    save(); // from parent A
    render(); // from parent A
  }

  // from parent B: delete by id
  function del(id) {
    todos = todos.filter(t => t.id !== id);
    save(); // from parent A
    render(); // from parent A
  }

  // from parent A: toggle done state
  function tog(id) {
    const t = todos.find(t => t.id === id);
    if (t) t.done = !t.done;
    save(); // from parent A
    render(); // from parent A
  }

  // from parent B: update text (used after editing)
  function upd(id, text) {
    const t = todos.find(t => t.id === id);
    if (t) { t.text = String(text || '').trim() || t.text; }
    save(); // from parent A
  }

  // from parent A: set filter and update active class
  function sync(newFilter) {
    filter = newFilter;
    [filterAll, filterActive, filterCompleted].forEach(b => b.classList.remove('active'));
    if (filter === 'all') filterAll.classList.add('active');
    else if (filter === 'active') filterActive.classList.add('active');
    else filterCompleted.classList.add('active');
    render(); // from parent A
  }

  // from parent A/B combined: render visible items respecting filter, and wire interactions
  function render() {
    list.innerHTML = '';
    const visible = todos.filter(t => {
      if (filter === 'active') return !t.done;
      if (filter === 'completed') return t.done;
      return true;
    });
    visible.forEach(t => {
      const li = document.createElement('li');
      li.dataset.testid = 'todo-item'; // from parent A
      li.setAttribute('role', 'listitem');

      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.dataset.testid = 'todo-toggle'; // from parent A
      cb.checked = t.done;
      cb.addEventListener('change', () => tog(t.id)); // from parent A

      const span = document.createElement('span');
      span.dataset.testid = 'todo-text'; // from parent A
      span.textContent = t.text;
      if (t.done) span.classList.add('done'); // from parent A

      // from parent B: editing by double-click -> contentEditable
      span.addEventListener('dblclick', () => {
        span.contentEditable = 'true';
        span.focus();
        // select all text for convenience
        const range = document.createRange();
        range.selectNodeContents(span);
        const sel = window.getSelection();
        sel.removeAllRanges();
        sel.addRange(range);
      });

      // from parent B: on blur save changes (or revert if necessary)
      span.addEventListener('blur', () => {
        span.contentEditable = 'false';
        upd(t.id, span.textContent); // from parent B
        const todo = todos.find(x => x.id === t.id);
        if (todo) span.textContent = todo.text; // reflect any trimming/cleanup
      });

      // from parent B: keyboard handling during edit
      span.addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); span.blur(); }
        if (e.key === 'Escape') { span.textContent = t.text; span.blur(); }
      });

      // from parent A: delete button
      const btn = document.createElement('button');
      btn.dataset.testid = 'todo-delete';
      btn.textContent = '削除';
      btn.addEventListener('click', () => del(t.id)); // from parent A

      li.appendChild(cb);
      li.appendChild(span);
      li.appendChild(btn);
      list.appendChild(li);
    });
  }

  // from parent A/B: event wiring for add via button and Enter key
  addBtn.addEventListener('click', () => {
    add(input.value); // from parent B
    input.value = ''; // from parent A
    input.focus(); // from parent A
  });

  input.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      add(input.value); // from parent B
      input.value = ''; // from parent A
    }
  });

  // from parent A: filter buttons
  filterAll.addEventListener('click', () => sync('all'));
  filterActive.addEventListener('click', () => sync('active'));
  filterCompleted.addEventListener('click', () => sync('completed'));

  // from parent B: clear completed items
  clearCompleted.addEventListener('click', () => {
    todos = todos.filter(t => !t.done);
    save(); // from parent A
    render(); // from parent A
  });

  // Initialize: load from storage then render (from parent B/A)
  load(); // from parent B
  render(); // from parent A

  // Accessibility small enhancement: allow Space on focused list items to toggle (optional)
  list.addEventListener('keydown', (e) => {
    const target = e.target;
    if (e.key === ' ' && target && target.dataset && target.dataset.testid === 'todo-text') {
      e.preventDefault();
      // find corresponding todo by matching text and index in visible list
      const li = target.closest('li[data-testid="todo-item"]');
      if (!li) return;
      // find index of li in rendered list to map to visible array
      const items = Array.from(list.querySelectorAll('li[data-testid="todo-item"]'));
      const idx = items.indexOf(li);
      const visible = todos.filter(t => {
        if (filter === 'active') return !t.done;
        if (filter === 'completed') return t.done;
        return true;
      });
      const todo = visible[idx];
      if (todo) tog(todo.id);
    }
  });
</script>
</body>
</html>