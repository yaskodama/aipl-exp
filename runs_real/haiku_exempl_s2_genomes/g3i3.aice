<!DOCTYPE html>
<html lang="ja"><head><meta charset="UTF-8"><title>Todo App</title><style>body{font-family:sans-serif;max-width:600px;margin:2em auto;padding:1em;background:#f5f5f5}h1{text-align:center;color:#333}.input-row{display:flex;gap:.5em;margin-bottom:1em}#new-todo-input{flex:1;padding:.5em;font-size:1em;border:1px solid #ddd;border-radius:4px}button{padding:.5em 1em;cursor:pointer;border:1px solid #999;background:#fff;border-radius:4px}button:hover{background:#f0f0f0}.filters{display:flex;gap:.5em;margin-bottom:1em;justify-content:center}button[data-testid^="filter-"]{padding:.5em 1em}button[data-testid^="filter-"].active{background:#4a90e2;color:#fff;border-color:#4a90e2}ul{list-style:none;padding:0;margin:0}li{display:flex;align-items:center;gap:.5em;padding:.8em;background:#fff;border-bottom:1px solid #eee}li:hover{background:#fafafa}li input{width:20px;height:20px;cursor:pointer}li span{flex:1;word-break:break-word}li.completed span{text-decoration:line-through;color:#888}li span[contenteditable="true"]{background:#fffbe6;outline:2px dashed #f5c000;padding:2px;border-radius:2px}button[data-testid="todo-delete"]{padding:.3em .6em;font-size:.9em;background:#ffebee;border-color:#ff6b6b;color:#d32f2f}button[data-testid="todo-delete"]:hover{background:#ff9999}.clear-row{text-align:center;margin-top:2em}button[data-testid="clear-completed"]{background:#fff3e0;border-color:#ff9800}</style></head><body>
<h1>Todo</h1>
<div class="input-row">
  <input type="text" data-testid="new-todo-input" placeholder="やることを入力">
  <button data-testid="add-btn">追加</button>
</div>
<div class="filters">
  <button data-testid="filter-all" class="active">全て</button>
  <button data-testid="filter-active">未完了</button>
  <button data-testid="filter-completed">完了</button>
</div>
<ul data-testid="todo-list"></ul>
<div class="clear-row"><button data-testid="clear-completed">完了を一括削除</button></div>
<script>
(()=>{const SK='todos.v1',FK='todos.filter',input=document.querySelector('[data-testid="new-todo-input"]'),list=document.querySelector('[data-testid="todo-list"]');let todos=[],filter='all';const save=()=>{localStorage.setItem(SK,JSON.stringify(todos));localStorage.setItem(FK,filter)};const add=text=>{if(!(text=(text||'').trim()))return;todos.push({id:Date.now()+Math.random(),text,completed:false});save();render()};const del=id=>{todos=todos.filter(t=>t.id!==id);save();render()};const tog=id=>{const t=todos.find(t=>t.id===id);t&&(t.completed=!t.completed,save(),render())};const upd=(id,text)=>{const t=todos.find(t=>t.id===id);if(!t)return;if(!(text=(text||'').trim())){del(id);return}t.text=text;save();render()};const setFilter=f=>{filter=f;document.querySelectorAll('button[data-testid^="filter-"]').forEach(b=>b.classList.toggle('active',b.dataset.testid===`filter-${f}`));save();render()};const render=()=>{list.innerHTML='';todos.forEach(t=>{if(filter==='active'&&t.completed||filter==='completed'&&!t.completed)return;const li=document.createElement('li');li.setAttribute('data-testid','todo-item');li.dataset.id=t.id;li.classList.toggle('completed',t.completed);const cb=document.createElement('input');cb.type='checkbox';cb.setAttribute('data-testid','todo-toggle');cb.checked=t.completed;cb.addEventListener('change',()=>tog(t.id));const span=document.createElement('span');span.setAttribute('data-testid','todo-text');span.textContent=t.text;span.addEventListener('dblclick',e=>{e.stopPropagation();span.contentEditable='true';span.focus();const r=document.createRange();r.selectNodeContents(span);window.getSelection().removeAllRanges();window.getSelection().addRange(r)});const fin=()=>{span.contentEditable='false';upd(t.id,span.textContent);const u=todos.find(x=>x.id===t.id);u&&(span.textContent=u.text)};span.addEventListener('blur',fin);span.addEventListener('keydown',e=>{e.key==='Enter'&&(e.preventDefault(),span.blur());e.key==='Escape'&&(e.preventDefault(),span.contentEditable='false',span.textContent=t.text)});const delBtn=document.createElement('button');delBtn.setAttribute('data-testid','todo-delete');delBtn.textContent='削除';delBtn.addEventListener('click',()=>del(t.id));li.append(cb,span,delBtn);list.appendChild(li)})};try{todos=JSON.parse(localStorage.getItem(SK)||'[]')}catch{}try{filter=localStorage.getItem(FK)||'all'}catch{}setFilter(filter);document.querySelector('[data-testid="add-btn"]').addEventListener('click',()=>{add(input.value);input.value='';input.focus()});input.addEventListener('keydown',e=>{e.key==='Enter'&&document.querySelector('[data-testid="add-btn"]').click()});document.querySelectorAll('button[data-testid^="filter-"]').forEach(btn=>btn.addEventListener('click',()=>setFilter(btn.dataset.testid.replace('filter-',''))));document.querySelector('[data-testid="clear-completed"]').addEventListener('click',()=>{todos=todos.filter(t=>!t.completed);save();render()});render()})();
</script></body></html>