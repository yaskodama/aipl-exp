<!DOCTYPE html>
<html lang="ja"><head><meta charset="UTF-8"><title>Todo App</title><style>body{font-family:sans-serif;max-width:600px;margin:2em auto;padding:1em;background:#f5f5f5}h1{text-align:center;color:#333}.input-row{display:flex;gap:.5em;margin-bottom:1em}#new-todo-input{flex:1;padding:.5em;font-size:1em;border:1px solid #ddd;border-radius:4px}button{padding:.5em 1em;cursor:pointer;border:1px solid #999;background:#fff;border-radius:4px}button:hover{background:#f0f0f0}.filters{display:flex;gap:.5em;margin-bottom:1em;justify-content:center}button[data-testid^="filter-"]{padding:.5em 1em}button[data-testid^="filter-"].active{background:#4a90e2;color:#fff;border-color:#4a90e2}ul{list-style:none;padding:0;margin:0}li{display:flex;align-items:center;gap:.5em;padding:.8em;background:#fff;border-bottom:1px solid #eee;margin-bottom:0}li:hover{background:#fafafa}li input[type="checkbox"]{width:20px;height:20px;cursor:pointer}li .todo-text{flex:1;word-break:break-word}li.completed .todo-text{text-decoration:line-through;color:#888}li .todo-text[contenteditable="true"]{background:#fffbe6;outline:2px dashed #f5c000;padding:2px;border-radius:2px}button[data-testid="todo-delete"]{padding:.3em .6em;font-size:.9em;background:#ffebee;border-color:#ff6b6b;color:#d32f2f}button[data-testid="todo-delete"]:hover{background:#ff9999}.clear-row{text-align:center;margin-top:2em}button[data-testid="clear-completed"]{background:#fff3e0;border-color:#ff9800}</style></head><body>
<h1>Todo</h1>
<div class="input-row">
  <input type="text" data-testid="new-todo-input" id="new-todo-input" placeholder="やることを入力">
  <button data-testid="add-btn" id="add-btn">追加</button>
</div>
<div class="filters">
  <button data-testid="filter-all" class="active">全て</button>
  <button data-testid="filter-active">未完了</button>
  <button data-testid="filter-completed">完了</button>
</div>
<ul data-testid="todo-list" id="todo-list"></ul>
<div class="clear-row"><button data-testid="clear-completed" id="clear-completed">完了を一括削除</button></div>
<script>
(()=>{const SK='todos.v1',FK='todos.filter';let todos=[],filter='all';const load=()=>{try{todos=JSON.parse(localStorage.getItem(SK)||'[]')}catch{todos=[]}try{filter=localStorage.getItem(FK)||'all'}catch{filter='all'}};const save=()=>{try{localStorage.setItem(SK,JSON.stringify(todos));localStorage.setItem(FK,filter)}catch{}};const add=text=>{text=(text||'').trim();if(!text)return;todos.push({id:Date.now()+Math.random(),text,completed:false});save();render()};const del=id=>{todos=todos.filter(t=>t.id!==id);save();render()};const tog=id=>{const t=todos.find(t=>t.id===id);if(t){t.completed=!t.completed;save();render()}};const upd=(id,text)=>{const t=todos.find(t=>t.id===id);if(!t)return;text=(text||'').trim();if(!text){del(id);return}t.text=text;save();render()};const getVisible=()=>{if(filter==='active')return todos.filter(t=>!t.completed);if(filter==='completed')return todos.filter(t=>t.completed);return todos};const setFilter=f=>{filter=f;document.querySelectorAll('button[data-testid^="filter-"]').forEach(b=>{b.classList.toggle('active',b.dataset.testid===`filter-${f}`)});save();render()};const clearCompleted=()=>{todos=todos.filter(t=>!t.completed);save();render()};const render=()=>{const list=document.getElementById('todo-list');list.innerHTML='';getVisible().forEach(t=>{const li=document.createElement('li');li.setAttribute('data-testid','todo-item');li.dataset.id=t.id;if(t.completed)li.classList.add('completed');const cb=document.createElement('input');cb.type='checkbox';cb.setAttribute('data-testid','todo-toggle');cb.checked=t.completed;cb.addEventListener('change',()=>tog(t.id));const span=document.createElement('span');span.setAttribute('data-testid','todo-text');span.className='todo-text';span.textContent=t.text;const delBtn=document.createElement('button');delBtn.setAttribute('data-testid','todo-delete');delBtn.textContent='削除';delBtn.addEventListener('click',()=>del(t.id));li.appendChild(cb);li.appendChild(span);li.appendChild(delBtn);span.addEventListener('dblclick',e=>{e.stopPropagation();span.contentEditable='true';span.focus();const range=document.createRange();range.selectNodeContents(span);const sel=window.getSelection();sel.removeAllRanges();sel.addRange(range)});span.addEventListener('blur',()=>{span.contentEditable='false';const newText=span.textContent;upd(t.id,newText);const updated=todos.find(x=>x.id===t.id);if(updated)span.textContent=updated.text});span.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();span.blur()}if(e.key==='Escape'){e.preventDefault();span.contentEditable='false';span.textContent=t.text}});list.appendChild(li)})};load();setFilter(filter);document.getElementById('add-btn').addEventListener('click',()=>{const input=document.getElementById('new-todo-input');add(input.value);input.value='';input.focus()});document.getElementById('new-todo-input').addEventListener('keydown',e=>{if(e.key==='Enter'){document.getElementById('add-btn').click()}});document.querySelectorAll('button[data-testid^="filter-"]').forEach(btn=>{btn.addEventListener('click',()=>{setFilter(btn.dataset.testid.replace('filter-',''))})});document.getElementById('clear-completed').addEventListener('click',clearCompleted);render()})();
</script></body></html>